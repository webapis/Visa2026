# Copy to .env.dev and fill values for development/test.
# Use the same value for SA_PASSWORD as Password= in Visa2026.Blazor.Server/appsettings.Development.json
# (or run migration-scripts/Sync-BlazorDevConnectionUserSecret.ps1 to push .env.dev into dotnet user-secrets).
SA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DEVEXPRESS_LICENSEKEY=CHANGE_ME_LICENSE_KEY

# Optional overrides
APP_PORT=8081
DB_NAME=Visa2026DbDev
# MCP (Cursor / Claude): the SQL MCP server reads SA_PASSWORD from your OS user environment
# (not from this file). Set SA_PASSWORD in Windows "Environment variables" to match SA_PASSWORD here.
# If SQL is not on host port 1433, set SQL_PORT in .cursor/mcp.json, .claude/mcp.json, and .mcp.json to match MSSQL_HOST_PORT.
# MSSQL_HOST_PORT=1433
APP_IMAGE_TAG=latest
IMPORTER_IMAGE_TAG=latest
# One-shot: FORCE_XAF_DB_UPDATE=true (then remove) — see ENVIRONMENTS.md
# FORCE_XAF_DB_UPDATE=true
