# Copy to .env.prod and fill values for production.
SA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DEVEXPRESS_LICENSEKEY=CHANGE_ME_LICENSE_KEY

# Optional overrides
APP_PORT=80
# SSMS on this PC: SQL is published at 127.0.0.1:MSSQL_HOST_PORT (default 1433). Change if another SQL uses 1433.
# MSSQL_HOST_PORT=14333
DB_NAME=Visa2026DbProd
APP_IMAGE_TAG=latest
IMPORTER_IMAGE_TAG=latest
# One-shot: FORCE_XAF_DB_UPDATE=true (then remove) to run all XAF ModuleUpdaters when UpdateOldDatabase would skip them.
# FORCE_XAF_DB_UPDATE=true
#setup master