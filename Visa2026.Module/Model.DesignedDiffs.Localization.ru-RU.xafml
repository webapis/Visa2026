  <Validation>
    <ErrorMessageTemplates>
      <RuleRequiredField MessageTemplateMustNotBeEmpty="&quot;{TargetPropertyName}&quot; не может быть пустым." />
    </ErrorMessageTemplates>
    <Rules>
      <RuleCriteria Id="BorderZone_DateRange" TargetType="Visa2026.Module.BusinessObjects.BorderZone" CustomMessageTemplate="Дата окончания должна быть позже даты начала." />
      <RuleCriteria Id="CompanyHeadSource" TargetType="Visa2026.Module.BusinessObjects.CompanyHead" CustomMessageTemplate="Выберите местного или иностранного сотрудника." />
      <RuleCriteria Id="DocumentFileNotEmpty" TargetType="Visa2026.Module.BusinessObjects.DocumentBase" CustomMessageTemplate="Загруженный файл пуст. Прикрепите непустой документ." />
      <RuleCriteria Id="EmployeeContract_DateRange" TargetType="Visa2026.Module.BusinessObjects.EmployeeContract" CustomMessageTemplate="Дата окончания должна быть позже даты начала договора." />
      <RuleRegularExpression Id="EmployeeEmailFormat" TargetType="Visa2026.Module.BusinessObjects.Person" CustomMessageTemplate="Неверный формат электронной почты." />
      <RuleCriteria Id="ImageNotEmpty" TargetType="Visa2026.Module.BusinessObjects.ImageBase" CustomMessageTemplate="Загруженное изображение пусто. Выберите непустой файл." />
      <RuleCriteria Id="ImageSizeIsTooLarge" TargetType="Visa2026.Module.BusinessObjects.ImageBase" CustomMessageTemplate="Размер изображения превышает допустимый лимит {MaxImageSizeInMB} МБ." />
      <RuleCriteria Id="Invitation_DateRange" TargetType="Visa2026.Module.BusinessObjects.Invitation" CustomMessageTemplate="Дата окончания должна быть позже даты начала." />
      <RuleRegularExpression Id="LocalEmployeeEmailFormat" TargetType="Visa2026.Module.BusinessObjects.LocalEmployee" CustomMessageTemplate="Неверный формат электронной почты." />
      <RuleCriteria Id="MedicalRecord_DateRange" TargetType="Visa2026.Module.BusinessObjects.MedicalRecord" CustomMessageTemplate="Дата окончания должна быть позже даты выдачи." />
      <RuleCriteria Id="Passport_DateRange" TargetType="Visa2026.Module.BusinessObjects.Passport" CustomMessageTemplate="Дата окончания должна быть позже даты выдачи." />
      <RuleCriteria Id="RepresentativeSource" TargetType="Visa2026.Module.BusinessObjects.Representative" CustomMessageTemplate="Выберите местного или иностранного сотрудника." />
      <RuleRequiredField Id="SyncRule_TargetValueRequired" TargetType="Visa2026.Module.BusinessObjects.SyncRule" CustomMessageTemplate="Целевое значение не может быть пустым." />
      <RuleValueComparison Id="SystemSettings_MaxDocumentSizeCap" TargetType="Visa2026.Module.BusinessObjects.SystemSettings" CustomMessageTemplate="Максимальный размер документа не может превышать {RightOperand} МБ (лимит сервера)." />
      <RuleValueComparison Id="SystemSettings_MaxImageSizeCap" TargetType="Visa2026.Module.BusinessObjects.SystemSettings" CustomMessageTemplate="Максимальный размер изображения не может превышать {RightOperand} МБ (лимит сервера)." />
      <RuleCriteria Id="Visa_ExpirationDate_GreaterThan_StartDate" TargetType="Visa2026.Module.BusinessObjects.Visa" CustomMessageTemplate="Дата окончания должна быть позже даты начала." />
      <RuleCriteria Id="WorkPermitItem_DateRange" TargetType="Visa2026.Module.BusinessObjects.WorkPermitItem" CustomMessageTemplate="Дата окончания должна быть позже даты начала." />
    </Rules>
  </Validation>
  <Localization>
    <Exceptions>
      <UserVisibleExceptions>
        <Validation AllContextsErrorMessageHeader="Ошибка проверки данных: просмотрите и исправьте ошибки проверки ниже." DeleteErrorMessageHeader="Ошибка проверки данных: просмотрите и исправьте ошибки проверки ниже, чтобы удалить запись." SaveErrorMessageHeader="Ошибка проверки данных: просмотрите и исправьте ошибки проверки ниже, чтобы продолжить." ValidationSucceededMessageHeader="Проверка выполнена успешно." />
      </UserVisibleExceptions>
    </Exceptions>
