  <Validation>
    <ErrorMessageTemplates>
      <RuleRequiredField MessageTemplateMustNotBeEmpty="&quot;{TargetPropertyName}&quot; boş bolmaly." />
    </ErrorMessageTemplates>
    <Rules>
      <RuleCriteria Id="BorderZone_DateRange" TargetType="Visa2026.Module.BusinessObjects.BorderZone" CustomMessageTemplate="Gutarýan senesi başlanýan senesinden soň bolmaly." />
      <RuleCriteria Id="CompanyHeadSource" TargetType="Visa2026.Module.BusinessObjects.CompanyHead" CustomMessageTemplate="Ýerli işgär ýa-da daşary ýurtly işgär saýlaň." />
      <RuleCriteria Id="DocumentFileNotEmpty" TargetType="Visa2026.Module.BusinessObjects.DocumentBase" CustomMessageTemplate="Ýüklenen faýl boş. Boş däl resminama goşuň." />
