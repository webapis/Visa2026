  <BOModel>
    <Class Name="DevExpress.Persistent.BaseImpl.EF.PermissionPolicy.PermissionPolicyUser" Caption="Base User" />
  <Class Name="Visa2026.Module.BusinessObjects.ApplicationLifecycleStage" Caption="Lifecycle stage"><OwnMembers><Member Name="Entry" Caption="Entry" /><Member Name="Exit" Caption="Exit" /><Member Name="Stay" Caption="Stay" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.ApplicationProgressRouteKind" Caption="Progress route"><OwnMembers><Member Name="DirectToMigrationService" Caption="Direct to migration" /><Member Name="ViaMinistries" Caption="Via ministries" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.ApplicationTypeCategory" Caption="Application category"><OwnMembers><Member Name="Both" Caption="Both" /><Member Name="Employee" Caption="Employee" /><Member Name="FamilyMember" Caption="Family member" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.ExpirationState"><OwnMembers><Member Name="Active" Caption="Active" /><Member Name="Archived" Caption="Archived" /><Member Name="Expired" Caption="Expired" /><Member Name="ExpiringSoon" Caption="ExpiringSoon" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.Feedback.UserFeedbackSeverity" Caption="Severity"><OwnMembers><Member Name="High" Caption="High" /><Member Name="Low" Caption="Low" /><Member Name="Medium" Caption="Medium" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.Feedback.UserFeedbackStatus" Caption="Status"><OwnMembers><Member Name="Fixed" Caption="Fixed" /><Member Name="InProgress" Caption="In progress" /><Member Name="New" Caption="New" /><Member Name="WontFix" Caption="Won't fix" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.Feedback.UserFeedbackType" Caption="Feedback type"><OwnMembers><Member Name="Bug" Caption="Bug" /><Member Name="Idea" Caption="Idea" /><Member Name="Other" Caption="Other" /><Member Name="Question" Caption="Question" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.MinistryReviewDepth" Caption="Ministry review depth"><OwnMembers><Member Name="FirstAndSecondMinistry" Caption="First and second ministry" /><Member Name="FirstMinistryOnly" Caption="First ministry only" /><Member Name="None" Caption="None" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.MovementType" Caption="Movement type"><OwnMembers><Member Name="Entry" Caption="Entry" /><Member Name="Exit" Caption="Exit" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.PdfBatchDiplomaScope" Caption="Diploma scope"><OwnMembers><Member Name="AllEducations" Caption="All educations" /><Member Name="CurrentEducationOnly" Caption="Current education only" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.PdfSupportingZipMergeOption" Caption="Supporting files in ZIP"><OwnMembers><Member Name="IndividualFilesAndMergedPdfs" Caption="Individual files + merged PDF summaries" /><Member Name="IndividualFilesOnly" Caption="Individual files only (no merged PDFs)" /><Member Name="MergedPdfSummariesOnly" Caption="Merged PDF summaries only (smaller ZIP)" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.PersonRecordRole" Caption="Person role"><OwnMembers><Member Name="Employee" Caption="Employee" /><Member Name="FamilyMember" Caption="Family member" /><Member Name="TemporaryVisitor" Caption="Temporary visitor" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.ResidenceType" Caption="Residence type"><OwnMembers><Member Name="Hotel" Caption="Hotel" /><Member Name="Lodging" Caption="Lodging" /><Member Name="PrivateHouse" Caption="Private house" /></OwnMembers></Class><Class Name="Visa2026.Module.BusinessObjects.TravelType" Caption="Travel type"><OwnMembers><Member Name="External" Caption="External" /><Member Name="Internal" Caption="Internal" /></OwnMembers></Class></BOModel>
  <Options>
    <LayoutManagerOptions RequiredFieldMark="*" />
  </Options>
  <Views>
    <ListView Id="ApplicationUser_ListView" Caption="Users" />
    <ListView Id="City_ListView" Criteria="IsMostlyUsed = true" />
    <DetailView Id="BoStateNotificationInboxHost_DetailView" Caption="State notifications" AllowDelete="False" AllowNew="False" AllowEdit="True" CustomCSSClassName="bo-state-inbox-detail">
      <Items>
        <PropertyEditor Id="InboxUi" PropertyName="InboxUi" ShowCaption="False" IsNewNode="True" />
      </Items>
      <Layout>
        <LayoutGroup Id="Main" Direction="Vertical" RelativeSize="100" CustomCSSClassName="xaf-fill-root">
          <LayoutGroup Id="SimpleEditors" ShowCaption="False" RelativeSize="100" CustomCSSClassName="xaf-fill-available">
            <LayoutGroup Id="BoStateNotificationInboxHost" ShowCaption="False" RelativeSize="100" CustomCSSClassName="xaf-fill-available">
              <LayoutItem Id="InboxUi" ViewItem="InboxUi" ShowCaption="False" RelativeSize="100" Index="0" IsNewNode="True" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>
    <DetailView Id="ApplicationItemDocumentCopiesListHost_DetailView" Caption="Document copies" AllowDelete="False" AllowNew="False" AllowEdit="True" CustomCSSClassName="app-item-doc-copies-list-detail">
      <Items>
        <PropertyEditor Id="ListUi" PropertyName="ListUi" ShowCaption="False" IsNewNode="True" />
      </Items>
      <Layout>
        <LayoutGroup Id="Main" Direction="Vertical" RelativeSize="100" CustomCSSClassName="xaf-fill-root">
          <LayoutGroup Id="SimpleEditors" ShowCaption="False" RelativeSize="100" CustomCSSClassName="xaf-fill-available">
            <LayoutGroup Id="ApplicationItemDocumentCopiesListHost" ShowCaption="False" RelativeSize="100" CustomCSSClassName="xaf-fill-available">
              <LayoutItem Id="ListUi" ViewItem="ListUi" ShowCaption="False" RelativeSize="100" Index="0" IsNewNode="True" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>
    <DetailView Id="ReportDataV2_DetailView">
      <Layout>
        <LayoutGroup Id="Main">
          <LayoutGroup Id="SimpleEditors">
            <LayoutGroup Id="ReportDataV2">
              <LayoutItem Id="DisplayName" ViewItem="DisplayName" Index="0" IsNewNode="True" Removed="True" />
              <LayoutItem Id="ParametersObjectType" ViewItem="ParametersObjectType" Index="1" IsNewNode="True" Removed="True" />
              <LayoutItem Id="DataTypeCaption" ViewItem="DataTypeCaption" Index="2" IsNewNode="True" Removed="True" />
              <LayoutItem Id="IsInplaceReport" Index="3" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>
    <ListView Id="Person_ListView_Employees" DetailViewID="Person_DetailView_Employee" />
    <ListView Id="Person_ListView_FamilyMembers" DetailViewID="Person_DetailView_FamilyMember" />
    <ListView Id="Person_ListView_TemporaryVisitors" Caption="Temporary visitor" DetailViewID="Person_DetailView_TemporaryVisitor" />
  </Views>
