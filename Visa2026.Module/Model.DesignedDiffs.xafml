<?xml version="1.0" ?>
<Application Title="Visa2026" PreferredLanguage="(User language)">
  <ActionDesign>
    <Actions>
      <Action Id="SoftDelete" Caption="Remove" />
      <Action Id="RestoreObject" Caption="Restore" />
      <Action Id="ToggleShowDeleted" Caption="Show Deleted" />
      <Action Id="GenerateApplicationPdfBatch" Caption="Generate PDF" />
      <Action Id="ShowMyPdfBatches" Caption="My PDF Jobs" />
      <Action Id="ShowInReport" Caption="Show in Report" />
      <Action Id="ShowInDocument" Caption="Show in document" />
      <Action Id="ResetSyncRules" Caption="Reset Rules" />
      <Action Id="ValidateSyncRules" Caption="Validate Rules" />
      <Action Id="ExtractPlaceholders" Caption="Extract Placeholders" />
      <Action Id="ValidatePlaceholders" Caption="Validate Placeholders" />
      <Action Id="RefreshPdfMappingsCache" Caption="Refresh Mappings" />
      <Action Id="ClearVisibilityCache" Caption="Clear Visibility Cache" />
      <Action Id="RefreshReportVisibilityCache" Caption="Refresh Report Visibility Cache" />
      <Action Id="DownloadAllApplicationItemsAsPdf" Caption="Download All as PDF" />
      <Action Id="OpenApplicationFromVisaStatus" Caption="Open Application" />
      <Action Id="OpenApplicationFromTransferStatus" Caption="Open Application" />
      <Action Id="CloneSyncRule" Caption="Clone Rule" />
      <Action Id="ReactivateObject" Caption="Reactivate" />
      <Action Id="GenerateWordReports" Caption="Resminamalar" />
      <Action Id="OpenSourceObject" Caption="Open Source Object" />
      <Action Id="OpenTargetObject" Caption="Open Target Object" />
    </Actions>
  </ActionDesign>
  <NavigationItems>
    <Items>
      <Item Id="People" Caption="People">
        <Items>
          <Item Id="Employees" Caption="Employees" />
          <Item Id="FamilyMembers" Caption="Family Members" />
        </Items>
      </Item>
    </Items>
  </NavigationItems>
  <BOModel>
    <Class Name="DevExpress.Persistent.BaseImpl.EF.PermissionPolicy.PermissionPolicyUser" Caption="Base User" />
  </BOModel>
  <Options>
    <LayoutManagerOptions RequiredFieldMark="*" />
  </Options>
  <Views>
    <ListView Id="ApplicationUser_ListView" Caption="Users" />
    <ListView Id="City_ListView" Criteria="IsMostlyUsed = true" />
    <DetailView Id="ReportDataV2_DetailView">
      <Layout>
        <LayoutGroup Id="Main" >
          <LayoutGroup Id="SimpleEditors" >
            <LayoutGroup Id="ReportDataV2" >
              <LayoutItem Id="DisplayName" ViewItem="DisplayName" Index="0" IsNewNode="True" Removed="True" />
              <LayoutItem Id="ParametersObjectType" ViewItem="ParametersObjectType" Index="1" IsNewNode="True" Removed="True" />
              <LayoutItem Id="DataTypeCaption" ViewItem="DataTypeCaption" Index="2" IsNewNode="True" Removed="True" />
              <LayoutItem Id="IsInplaceReport" Index="3" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>
  </Views>
</Application>
