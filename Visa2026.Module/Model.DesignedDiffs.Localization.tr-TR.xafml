  <Validation>
    <ErrorMessageTemplates>
      <RuleRequiredField MessageTemplateMustNotBeEmpty="&quot;{TargetPropertyName}&quot; boş olamaz." />
    </ErrorMessageTemplates>
    <Rules>
      <RuleCriteria Id="BorderZone_DateRange" TargetType="Visa2026.Module.BusinessObjects.BorderZone" CustomMessageTemplate="Bitiş tarihi, başlangıç tarihinden sonra olmalıdır." />
      <RuleCriteria Id="CompanyHeadSource" TargetType="Visa2026.Module.BusinessObjects.CompanyHead" CustomMessageTemplate="Yerel çalışan veya yabancı çalışan seçin." />
      <RuleCriteria Id="DocumentFileNotEmpty" TargetType="Visa2026.Module.BusinessObjects.DocumentBase" CustomMessageTemplate="Yüklenen dosya boş. Boş olmayan bir belge ekleyin." />
      <RuleCriteria Id="EmployeeContract_DateRange" TargetType="Visa2026.Module.BusinessObjects.EmployeeContract" CustomMessageTemplate="Bitiş tarihi, sözleşme başlangıç tarihinden sonra olmalıdır." />
