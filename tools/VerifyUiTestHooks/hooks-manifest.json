{
  "version": 1,
  "scenarios": [
    {
      "id": "login",
      "description": "AuthenticationStandardLogonParameters logon view",
      "startPath": "/LoginPage",
      "requiresAuth": false,
      "checks": [
        {
          "id": "login-user-name",
          "target": "UserName",
          "type": "text-input",
          "selectors": [
            "#login-user-name",
            "[data-testid=\"login-user-name\"]",
            ".e2e-login-user-name"
          ]
        },
        {
          "id": "login-password",
          "target": "Password",
          "type": "password-input",
          "selectors": [
            "#login-password",
            "[data-testid=\"login-password\"]",
            ".e2e-login-password"
          ]
        },
        {
          "id": "login-submit",
          "target": "Logon",
          "type": "button",
          "selectors": [
            "[data-testid=\"login-submit\"]",
            ".e2e-login-submit"
          ],
          "clickOnBehavior": false
        }
      ]
    },
    {
      "id": "person-employee-tabs",
      "description": "Person employee detail — TabbedGroup Tabs (requires an open Person_DetailView_Employee URL)",
      "requiresAuth": true,
      "startPathEnv": "VISA2026_HOOK_VERIFY_PERSON_URL",
      "checks": [
        {
          "id": "person-employee-tabs",
          "target": "Tabs (strip)",
          "type": "exists",
          "selectors": [
            "[data-testid=\"person-employee-tabs\"]",
            ".e2e-person-employee-tabs"
          ]
        },
        {
          "id": "person-employee-tab-educations",
          "target": "Educations",
          "type": "layout-tab",
          "selectors": [
            "[data-testid=\"person-employee-tab-educations\"]",
            ".e2e-person-employee-tab-educations"
          ]
        },
        {
          "id": "person-employee-tab-passports",
          "target": "Passports",
          "type": "layout-tab",
          "selectors": [
            "[data-testid=\"person-employee-tab-passports\"]",
            ".e2e-person-employee-tab-passports"
          ]
        }
      ]
    },
    {
      "id": "nav-people",
      "description": "Sidebar People navigation group and child items (requires logon; expand People if collapsed)",
      "requiresAuth": true,
      "startPath": "/",
      "checks": [
        {
          "id": "nav-people",
          "target": "People",
          "type": "layout-tab",
          "selectors": [
            "[data-testid=\"nav-people\"]",
            ".e2e-nav-people"
          ],
          "clickOnBehavior": true
        },
        {
          "id": "nav-people-employees",
          "target": "Employees",
          "type": "button",
          "selectors": [
            "[data-testid=\"nav-people-employees\"]",
            ".e2e-nav-people-employees"
          ],
          "clickOnBehavior": false
        },
        {
          "id": "nav-people-family-members",
          "target": "FamilyMembers",
          "type": "exists",
          "selectors": [
            "[data-testid=\"nav-people-family-members\"]",
            ".e2e-nav-people-family-members"
          ]
        },
        {
          "id": "nav-people-temporary-visitors",
          "target": "TemporaryVisitors",
          "type": "exists",
          "selectors": [
            "[data-testid=\"nav-people-temporary-visitors\"]",
            ".e2e-nav-people-temporary-visitors"
          ]
        }
      ]
    },
    {
      "id": "person-scalar-fields",
      "description": "Person required / always-visible scalar detail fields (pending DevTools verify)",
      "requiresAuth": true,
      "startPathEnv": "VISA2026_HOOK_VERIFY_PERSON_URL",
      "checks": [
        { "id": "person-first-name", "target": "FirstName", "type": "text-input", "selectors": ["#person-first-name", "[data-testid=\"person-first-name\"]", ".e2e-person-first-name"] },
        { "id": "person-last-name", "target": "LastName", "type": "text-input", "selectors": ["#person-last-name", "[data-testid=\"person-last-name\"]", ".e2e-person-last-name"] },
        { "id": "person-personal-number", "target": "PersonalNumber", "type": "exists", "selectors": ["#person-personal-number", "[data-testid=\"person-personal-number\"]", ".e2e-person-personal-number"] },
        { "id": "person-date-of-birth", "target": "DateOfBirth", "type": "exists", "selectors": ["#person-date-of-birth", "[data-testid=\"person-date-of-birth\"]", ".e2e-person-date-of-birth"] },
        { "id": "person-birth-place", "target": "BirthPlace", "type": "exists", "selectors": ["#person-birth-place", "[data-testid=\"person-birth-place\"]", ".e2e-person-birth-place"] },
        { "id": "person-country-of-birth", "target": "CountryOfBirth", "type": "exists", "selectors": ["[data-testid=\"person-country-of-birth\"]", ".e2e-person-country-of-birth"] },
        { "id": "person-gender", "target": "Gender", "type": "exists", "selectors": ["[data-testid=\"person-gender\"]", ".e2e-person-gender"] },
        { "id": "person-marital-status", "target": "MaritalStatus", "type": "exists", "selectors": ["[data-testid=\"person-marital-status\"]", ".e2e-person-marital-status"] },
        { "id": "person-nationality", "target": "Nationality", "type": "exists", "selectors": ["[data-testid=\"person-nationality\"]", ".e2e-person-nationality"] },
        { "id": "person-foreign-address", "target": "ForeignAddress", "type": "exists", "selectors": ["#person-foreign-address", "[data-testid=\"person-foreign-address\"]", ".e2e-person-foreign-address"] },
        { "id": "person-foreign-address-country", "target": "ForeignAddressCountry", "type": "exists", "selectors": ["[data-testid=\"person-foreign-address-country\"]", ".e2e-person-foreign-address-country"] },
        { "id": "person-project-contract", "target": "ProjectContract", "type": "exists", "selectors": ["[data-testid=\"person-project-contract\"]", ".e2e-person-project-contract"] },
        { "id": "person-visa-application-family-members-text", "target": "VisaApplicationFamilyMembersText", "type": "exists", "selectors": ["[data-testid=\"person-visa-application-family-members-text\"]", ".e2e-person-visa-application-family-members-text"] },
        { "id": "person-relationship", "target": "Relationship", "type": "exists", "selectors": ["[data-testid=\"person-relationship\"]", ".e2e-person-relationship"] },
        { "id": "person-subcontractor", "target": "Subcontractor", "type": "exists", "selectors": ["[data-testid=\"person-subcontractor\"]", ".e2e-person-subcontractor"] }
      ]
    }
  ]
}
