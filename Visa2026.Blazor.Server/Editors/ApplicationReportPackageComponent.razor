@namespace Visa2026.Blazor.Server.Editors
@using DevExpress.Blazor
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using DevExpress.ExpressApp.Blazor.Services
@using Microsoft.AspNetCore.Http
@using Visa2026.Blazor.Server.Localization
@using Visa2026.Blazor.Server.Services
@using Visa2026.Module.Localization
@using Visa2026.Module.Services
@using Visa2026.Module.Services.WordReports

<div class="app-report-package app-item-doc-copies">
    @if (ApplicationId != Guid.Empty && CatalogEntries.Count > 0)
    {
        <div class="app-item-doc-copies__top-actions app-report-package__top-selection">
            <DxButton Text="@Msg("ApplicationReportPackage.SelectAll")"
                      RenderStyle="ButtonRenderStyle.Link"
                      SizeMode="SizeMode.Small"
                      CssClass="app-item-doc-copies__action-btn"
                      Click="@SelectAllAsync" />
            <DxButton Text="@Msg("ApplicationReportPackage.ClearSelection")"
                      RenderStyle="ButtonRenderStyle.Link"
                      SizeMode="SizeMode.Small"
                      CssClass="app-item-doc-copies__action-btn"
                      Click="@ClearSelectionAsync" />
        </div>
    }
    <div class="app-item-doc-copies__body">
        @if (ApplicationId == Guid.Empty || CatalogEntries.Count == 0)
        {
            <div class="app-item-doc-copies__empty" role="status">
                <p>@Msg("ApplicationReportPackage.Empty")</p>
            </div>
        }
        else
        {
            var systemHeaderShown = false;
            var customHeaderShown = false;
            <div class="app-item-doc-copies__groups">
                @foreach (var entry in CatalogEntries)
                {
                    if (entry.Source == ApplicationWordReportPackageEntrySource.System && !systemHeaderShown)
                    {
                        systemHeaderShown = true;
                        <h3 class="app-report-package__section-title">@Msg("ApplicationReportPackage.SectionSystem")</h3>
                    }
                    if (entry.Source == ApplicationWordReportPackageEntrySource.User && !customHeaderShown)
                    {
                        customHeaderShown = true;
                        <h3 class="app-report-package__section-title">@Msg("ApplicationReportPackage.SectionCustom")</h3>
                    }

                    <section class="@GetEntryCssClass(entry, IsSelected(entry))" aria-label="@entry.DisplayName">
                        <div class="app-item-doc-copies__group-head">
                            <label class="app-report-package__include">
                                <input type="checkbox"
                                       checked="@IsSelected(entry)"
                                       @onchange="e => OnIncludeChanged(entry, e)" />
                                <span class="app-item-doc-copies__group-label">@entry.DisplayName</span>
                                <span class="app-report-package__format-badge">@FormatKind(entry.Kind)</span>
                            </label>
                            <div class="app-report-package__entry-actions">
                                <span class="app-report-package__readiness @GetReadinessCssClass(entry)">
                                    @ReadinessLabel(entry)
                                </span>
                                @if (IsPreviewingEntry(entry))
                                {
                                    <span class="app-report-package__preview-busy-label" role="status">
                                        @FormatMsg("ApplicationReportPackage.Preview.Downloading", entry.DisplayName)
                                    </span>
                                }
                                else
                                {
                                    <DxButton Text="@Msg("ApplicationReportPackage.Preview")"
                                              RenderStyle="ButtonRenderStyle.Link"
                                              SizeMode="SizeMode.Small"
                                              CssClass="app-item-doc-copies__action-btn"
                                              Enabled="@(!_packageBusy && !_previewBusy)"
                                              Click="@(() => PreviewEntryAsync(entry))" />
                                }
                            </div>
                        </div>
                        @if (IsPreviewingEntry(entry))
                        {
                            <div class="app-report-package__entry-progress" role="progressbar" aria-busy="true"
                                 aria-label="@FormatMsg("ApplicationReportPackage.Preview.Downloading", entry.DisplayName)">
                                <div class="app-report-package__preview-progress-track">
                                    <div class="app-report-package__preview-progress-indeterminate"></div>
                                </div>
                            </div>
                        }
                        <div class="app-item-doc-copies__status">
                            @if (!string.IsNullOrWhiteSpace(entry.OutputFileName))
                            {
                                <p class="app-item-doc-copies__summary">@entry.OutputFileName</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(entry.ReadinessMessageKey))
                            {
                                <p class="app-item-doc-copies__hint app-item-doc-copies__hint--warning">@Msg(entry.ReadinessMessageKey)</p>
                            }
                            @if (entry.ReadinessHints.Count > 0)
                            {
                                <ul class="app-report-package__hints">
                                    @foreach (var hint in entry.ReadinessHints)
                                    {
                                        <li class="app-report-package__hint">@FormatHint(hint)</li>
                                    }
                                </ul>
                            }
                        </div>
                    </section>
                }
            </div>
        }
    </div>

    @if (ApplicationId != Guid.Empty && CatalogEntries.Count > 0)
    {
        <footer class="app-item-doc-copies__footer">
            <div class="app-item-doc-copies__package-bar">
                <div class="app-item-doc-copies__package-bar-main">
                    <p class="app-item-doc-copies__subtitle">@GetSubtitle()</p>
                    @if (_packageConfirmPending)
                    {
                        <p class="app-item-doc-copies__toolbar-hint">@Msg("ApplicationReportPackage.PackageConfirmPrompt")</p>
                    }
                    else if (!string.IsNullOrWhiteSpace(_packageStatusMessage))
                    {
                        <p class="app-item-doc-copies__toolbar-hint @(_packageStatusIsError ? "app-item-doc-copies__toolbar-hint--error" : string.Empty)"
                           role="@(_packageStatusIsError ? "alert" : "status")">
                            @_packageStatusMessage
                        </p>
                    }
                </div>
                <div class="app-item-doc-copies__package-bar-actions">
                    @if (_packageConfirmPending)
                    {
                        <DxButton Text="@Msg("ApplicationReportPackage.PackageConfirmDownload")"
                                  RenderStyle="ButtonRenderStyle.Link"
                                  SizeMode="SizeMode.Small"
                                  CssClass="app-item-doc-copies__action-btn"
                                  Enabled="@(!_packageBusy && SelectedCount > 0)"
                                  Click="@ConfirmDownloadPackageAsync" />
                        <DxButton Text="@Msg("ApplicationReportPackage.PackageCancelConfirm")"
                                  RenderStyle="ButtonRenderStyle.Link"
                                  SizeMode="SizeMode.Small"
                                  CssClass="app-item-doc-copies__action-btn"
                                  Click="@CancelPackageConfirm" />
                    }
                    else
                    {
                        <DxButton Text="@Msg("ApplicationReportPackage.DownloadPackage")"
                                  RenderStyle="ButtonRenderStyle.Link"
                                  SizeMode="SizeMode.Small"
                                  CssClass="app-item-doc-copies__action-btn"
                                  Enabled="@(!_packageBusy && SelectedCount > 0)"
                                  Click="@OnDownloadPackageClickAsync" />
                    }
                    <DxButton Text="@Msg("ApplicationReportPackage.Refresh")"
                              RenderStyle="ButtonRenderStyle.Link"
                              SizeMode="SizeMode.Small"
                              CssClass="app-item-doc-copies__action-btn"
                              Click="@OnRefreshClick" />
                </div>
            </div>
        </footer>
    }
</div>

<ApplicationReportPackagePreviewDialog @ref="_previewDialog" />

@code {
    [Parameter] public Guid ApplicationId { get; set; }
    [Parameter] public WordReportPackageScope PackageScope { get; set; } = WordReportPackageScope.Application;
    [Parameter] public IReadOnlyList<Guid> ApplicationItemIds { get; set; } = Array.Empty<Guid>();
    [Parameter] public string ApplicationNumber { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<ApplicationWordReportPackageCatalogEntry> CatalogEntries { get; set; } =
        Array.Empty<ApplicationWordReportPackageCatalogEntry>();
    [Parameter] public EventCallback RefreshRequested { get; set; }
    [Parameter] public string UiCultureName { get; set; } = string.Empty;

    [Inject] private ApplicationWordReportPackageEnqueueService PackageEnqueueService { get; set; } = null!;
    [Inject] private IXafCultureInfoService CultureInfoService { get; set; } = null!;
    [Inject] private IHttpContextAccessor HttpContextAccessor { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private ApplicationReportPackagePreviewDialog? _previewDialog;

    private readonly HashSet<string> _selectedKeys = new(StringComparer.Ordinal);
    private bool _selectionInitialized;
    private bool _packageConfirmPending;
    private bool _packageBusy;
    private bool _previewBusy;
    private string? _previewEntryKey;

    private string _packageStatusMessage = string.Empty;
    private bool _packageStatusIsError;

    private int SelectedCount => _selectedKeys.Count;

    private ApplicationWordReportPackageReadinessSummary SelectedReadinessSummary =>
        ApplicationWordReportPackageReadinessSummary.Compute(CatalogEntries, _selectedKeys);

    protected override void OnParametersSet()
    {
        var currentKeys = CatalogEntries
            .Select(entry => entry.EntryKey)
            .ToHashSet(StringComparer.Ordinal);

        if (_selectionInitialized)
        {
            _selectedKeys.IntersectWith(currentKeys);
            return;
        }

        _selectedKeys.Clear();
        foreach (var key in currentKeys)
            _selectedKeys.Add(key);

        _selectionInitialized = currentKeys.Count > 0;
    }

    private string EffectiveUiCulture =>
        VisaUiCultureResolver.Resolve(CultureInfoService, HttpContextAccessor.HttpContext, UiCultureName);

    private string Msg(string key) => VisaUiMessages.Get(key, EffectiveUiCulture);

    private string FormatMsg(string key, params object[] args) =>
        VisaUiMessages.FormatForCulture(EffectiveUiCulture, key, args);

    private string GetSubtitle() =>
        FormatMsg("ApplicationReportPackage.SubtitleSelected", SelectedCount, CatalogEntries.Count, ApplicationNumber);

    private bool IsSelected(ApplicationWordReportPackageCatalogEntry entry) =>
        _selectedKeys.Contains(entry.EntryKey);

    private void OnIncludeChanged(ApplicationWordReportPackageCatalogEntry entry, ChangeEventArgs e)
    {
        var isChecked = e.Value is bool b && b;
        if (isChecked)
            _selectedKeys.Add(entry.EntryKey);
        else
            _selectedKeys.Remove(entry.EntryKey);

        _packageConfirmPending = false;
        ClearStatusMessages();
    }

    private Task SelectAllAsync()
    {
        foreach (var entry in CatalogEntries)
            _selectedKeys.Add(entry.EntryKey);
        _packageConfirmPending = false;
        ClearStatusMessages();
        return Task.CompletedTask;
    }

    private Task ClearSelectionAsync()
    {
        _selectedKeys.Clear();
        _packageConfirmPending = false;
        ClearStatusMessages();
        return Task.CompletedTask;
    }

    private static string FormatKind(ApplicationWordReportPackageEntryKind kind) =>
        kind switch
        {
            ApplicationWordReportPackageEntryKind.UserExcel => ".xlsx",
            _ => ".docx"
        };

    private string ReadinessLabel(ApplicationWordReportPackageCatalogEntry entry) =>
        entry.Readiness == ApplicationWordReportPackageReadinessLevel.Warning
            ? Msg("ApplicationReportPackage.Readiness.Warning")
            : Msg("ApplicationReportPackage.Readiness.Ready");

    private string GetEntryCssClass(ApplicationWordReportPackageCatalogEntry entry, bool isSelected) =>
        IsPreviewingEntry(entry)
            ? $"{GetEntryStateCssClass(entry, isSelected)} app-report-package__entry--previewing"
            : GetEntryStateCssClass(entry, isSelected);

    private static string GetEntryStateCssClass(ApplicationWordReportPackageCatalogEntry entry, bool isSelected)
    {
        var stateClass = !isSelected
            ? "app-report-package__entry--unchecked"
            : entry.Readiness == ApplicationWordReportPackageReadinessLevel.Warning
                ? "app-report-package__entry--warning"
                : "app-report-package__entry--ready";
        return $"app-item-doc-copies__group app-report-package__entry {stateClass}";
    }

    private static string GetReadinessCssClass(ApplicationWordReportPackageCatalogEntry entry) =>
        entry.Readiness == ApplicationWordReportPackageReadinessLevel.Warning
            ? "app-report-package__readiness--warning"
            : "app-report-package__readiness--ready";

    private async Task OnRefreshClick()
    {
        _packageConfirmPending = false;
        ClearStatusMessages();
        if (RefreshRequested.HasDelegate)
            await RefreshRequested.InvokeAsync();
    }

    private Task OnDownloadPackageClickAsync()
    {
        if (SelectedCount == 0)
        {
            _packageStatusMessage = Msg("ApplicationReportPackage.EnqueueErrorNoSelection");
            _packageStatusIsError = true;
            return Task.CompletedTask;
        }

        if (SelectedReadinessSummary.HasWarnings)
        {
            _packageConfirmPending = true;
            ClearStatusMessages();
            return Task.CompletedTask;
        }

        return EnqueuePackageAsync();
    }

    private Task ConfirmDownloadPackageAsync()
    {
        _packageConfirmPending = false;
        return EnqueuePackageAsync();
    }

    private Task CancelPackageConfirm()
    {
        _packageConfirmPending = false;
        return Task.CompletedTask;
    }

    private string FormatHint(ApplicationWordReportPackageReadinessHint hint) =>
        hint.FormatArgs.Count == 0
            ? Msg(hint.MessageKey)
            : FormatMsg(hint.MessageKey, hint.FormatArgs.Cast<object>().ToArray());

    private bool IsPreviewingEntry(ApplicationWordReportPackageCatalogEntry entry) =>
        _previewBusy
        && !string.IsNullOrWhiteSpace(_previewEntryKey)
        && string.Equals(_previewEntryKey, entry.EntryKey, StringComparison.Ordinal);

    private async Task PreviewEntryAsync(ApplicationWordReportPackageCatalogEntry entry)
    {
        if (ApplicationId == Guid.Empty || _previewBusy || _packageBusy || _previewDialog == null)
            return;

        ClearStatusMessages();
        _previewBusy = true;
        _previewEntryKey = entry.EntryKey;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            await _previewDialog.OpenAsync(ApplicationId, entry.EntryKey, entry.DisplayName, ApplicationItemIds);
        }
        finally
        {
            _previewBusy = false;
            _previewEntryKey = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task EnqueuePackageAsync()
    {
        if (_packageBusy || ApplicationId == Guid.Empty || SelectedCount == 0)
            return;

        _packageBusy = true;
        ClearStatusMessages();

        try
        {
            var outcome = await PackageEnqueueService.EnqueuePackageAsync(
                ApplicationId,
                _selectedKeys.ToList(),
                ApplicationItemIds);

            if (!outcome.Success)
            {
                _packageStatusMessage = outcome.ErrorMessage ?? Msg("ApplicationReportPackage.Package.Error");
                _packageStatusIsError = true;
                return;
            }

            await JS.InvokeVoidAsync("visaWordBatchToast.setCurrentBatchId", outcome.BatchId.ToString("D"));
            _packageStatusMessage = FormatMsg("ApplicationReportPackage.Package.Queued", outcome.ReportCount);
            _packageStatusIsError = false;
        }
        finally
        {
            _packageBusy = false;
        }
    }

    private void ClearStatusMessages()
    {
        _packageStatusMessage = string.Empty;
        _packageStatusIsError = false;
        _previewEntryKey = null;
    }
}
