@namespace Visa2026.Blazor.Server.Editors
@using DevExpress.Blazor
@using Microsoft.AspNetCore.Components
@using System.IO
@using System.IO.Compression
@using Microsoft.JSInterop
@using DevExpress.ExpressApp.Blazor.Services
@using Microsoft.AspNetCore.Http
@using Visa2026.Blazor.Server.Localization
@using Visa2026.Blazor.Server.Services
@using Visa2026.Module.Localization
@using Visa2026.Module.Services
@using Visa2026.Module.Services.WordReports
@using Visa2026.Module.Services.RuntimeLogging

<DxPopup Visible="_visible"
         VisibleChanged="OnVisibleChanged"
         ShowFooter="false"
         ShowCloseButton="false"
         CloseOnOutsideClick="false"
         AllowDrag="true"
         AllowResize="@_windowState.AllowResize"
         Scrollable="false"
         Width="@_windowState.Width"
         Height="@_windowState.Height"
         VerticalAlignment="@_windowState.VerticalAlignment"
         HorizontalAlignment="@_windowState.HorizontalAlignment"
         MinWidth="480px"
         MinHeight="360px"
         MaxWidth="98vw"
         MaxHeight="95vh"
         ResizeStarted="OnResizeStarted"
         ResizeCompleted="OnResizeCompleted"
         Shown="OnPopupShown"
         CssClass="@_windowState.GetPopupCssClass("app-item-doc-copies-preview-popup app-report-package-preview-popup")"
         Attributes="@PopupAttributes">
    <HeaderContentTemplate>
        <div class="app-item-doc-copies-preview__header">
            <h2 class="app-item-doc-copies-preview__title" id="app-report-package-preview-title">@HeaderText</h2>
            <div class="app-item-doc-copies-preview__header-toolbar">
                <div class="app-item-doc-copies-preview__header-actions">
                    @if (!_loading && HasOfficeDownload)
                    {
                        <DxButton Text="@ActionDownloadOffice"
                                  RenderStyle="ButtonRenderStyle.Link"
                                  SizeMode="SizeMode.Small"
                                  Click="@DownloadOfficeFileAsync" />
                    }
                    @if (!_loading && _pdfDownloadContent != null)
                    {
                        <DxButton Text="@ActionDownloadPdf"
                                  RenderStyle="ButtonRenderStyle.Link"
                                  SizeMode="SizeMode.Small"
                                  Click="@DownloadPreviewPdfAsync" />
                    }
                </div>
                <div class="app-item-doc-copies-preview__header-chrome">
                    <DocumentPreviewPopupWindowButtons IsMinimized="@_windowState.IsMinimized"
                                                       IsMaximized="@_windowState.IsMaximized"
                                                       AriaLabel="@WindowControlsLabel"
                                                       MinimizeLabel="@WindowMinimizeLabel"
                                                       MaximizeLabel="@WindowMaximizeLabel"
                                                       RestoreLabel="@WindowRestoreLabel"
                                                       OnMinimize="@ToggleMinimizeAsync"
                                                       OnMaximizeToggle="@ToggleMaximizeAsync"
                                                       OnRestore="@ToggleMinimizeAsync" />
                    <DxButton Text="@ActionClose"
                              RenderStyle="ButtonRenderStyle.Primary"
                              SizeMode="SizeMode.Small"
                              Click="@CloseAsync" />
                </div>
            </div>
        </div>
    </HeaderContentTemplate>
    <BodyContentTemplate>
        <div class="app-item-doc-copies-preview">
            @if (_loading)
            {
                <div class="app-item-doc-copies-preview__state app-item-doc-copies-preview__state--loading" role="status" aria-live="polite">
                    <div class="app-item-doc-copies-preview__loading">
                        <span class="app-report-package__preview-busy-label">@_previewLoadingLabel</span>
                        <div class="app-report-package__entry-progress" role="progressbar" aria-busy="true"
                             aria-label="@_previewLoadingLabel">
                            <div class="app-report-package__preview-progress-track">
                                <div class="app-report-package__preview-progress-indeterminate"></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="app-item-doc-copies-preview__state app-item-doc-copies-preview__state--error" role="alert">
                    <p>@_error</p>
                    @if (HasOfficeDownload)
                    {
                        <DxButton Text="@ActionDownloadOffice"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  SizeMode="SizeMode.Small"
                                  Click="@DownloadOfficeFileAsync" />
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_pdfBlobUrl))
            {
                <div class="app-item-doc-copies-preview__viewer-shell">
                    <iframe class="app-item-doc-copies-preview__iframe"
                            src="@_pdfBlobUrl"
                            title="@_fileName"
                            allow="fullscreen"></iframe>
                </div>
            }
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    [Inject] private ApplicationWordReportPackageFileAccess PreviewFileAccess { get; set; } = null!;
    [Inject] private IFileDownloader FileDownloader { get; set; } = null!;
    [Inject] private IXafCultureInfoService CultureInfoService { get; set; } = null!;
    [Inject] private IHttpContextAccessor HttpContextAccessor { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;
    [Inject] private IApplicationErrorReporter ErrorReporter { get; set; } = null!;

    private bool _visible;
    private string _fileName = string.Empty;
    private string _error = string.Empty;
    private bool _loading;
    private string? _pdfBlobUrl;
    private byte[]? _pdfDownloadContent;
    private string _pdfDownloadFileName = string.Empty;
    private byte[]? _officeDownloadContent;
    private string _officeDownloadFileName = string.Empty;
    private string _officeContentType = "application/octet-stream";
    private IReadOnlyList<ApplicationWordReportGeneratedFile> _officeOriginals = Array.Empty<ApplicationWordReportGeneratedFile>();
    private readonly DocumentPreviewPopupWindowState _windowState = new();
    private int _layoutSyncGeneration;
    private string _previewLoadingLabel = string.Empty;

    private Dictionary<string, object> PopupAttributes => new()
    {
        ["aria-labelledby"] = "app-report-package-preview-title"
    };

    private string EffectiveUiCulture =>
        VisaUiCultureResolver.Resolve(CultureInfoService, HttpContextAccessor.HttpContext);

    private string Msg(string key) => VisaUiMessages.Get(key, EffectiveUiCulture);

    private string FormatMsg(string key, params object[] args) =>
        VisaUiMessages.FormatForCulture(EffectiveUiCulture, key, args);

    private string HeaderText
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_fileName))
                return PreviewTitle;

            return _officeOriginals.Count > 1
                ? FormatMsg("ApplicationReportPackage.Preview.TitleMulti", _officeOriginals.Count, _fileName)
                : $"{PreviewTitle}: {_fileName}";
        }
    }

    private bool HasOfficeDownload =>
        _officeOriginals.Count > 0 || (_officeDownloadContent != null && _officeDownloadContent.Length > 0);

    private string ActionDownloadOffice =>
        _officeOriginals.Count > 1
            ? Msg("ApplicationReportPackage.Preview.DownloadOfficeZip")
            : Msg("ApplicationReportPackage.Preview.DownloadOffice");

    private string PreviewTitle => Msg("ApplicationReportPackage.Preview.Title");
    private string PreviewError => Msg("ApplicationReportPackage.Preview.Error");
    private string PdfConversionError => Msg("ApplicationReportPackage.Preview.PdfConversionError");

    private void SetPreviewError(string message, Exception? exception = null)
    {
        _error = message;
        ErrorReporter.ReportReportPackageError(
            message,
            ApplicationRuntimeLogCategories.ReportPackagePreviewDialog,
            exception);
    }

    private string ActionClose => Msg("ApplicationItemDocumentCopies.Action.Close");
    private string ActionDownloadPdf => Msg("ApplicationItemDocumentCopies.Action.Download");
    private string WindowControlsLabel => Msg("ApplicationDocumentPreview.Window.Controls");
    private string WindowMinimizeLabel => Msg("ApplicationDocumentPreview.Window.Minimize");
    private string WindowMaximizeLabel => Msg("ApplicationDocumentPreview.Window.Maximize");
    private string WindowRestoreLabel => Msg("ApplicationDocumentPreview.Window.Restore");

    public async Task OpenAsync(
        Guid applicationId,
        string entryKey,
        string displayName,
        IReadOnlyList<Guid>? applicationItemIds = null)
    {
        _officeDownloadContent = null;
        _officeDownloadFileName = string.Empty;
        _officeContentType = "application/octet-stream";
        _officeOriginals = Array.Empty<ApplicationWordReportGeneratedFile>();
        _pdfDownloadContent = null;
        _pdfDownloadFileName = string.Empty;
        _fileName = displayName;
        _previewLoadingLabel = FormatMsg("ApplicationReportPackage.Preview.Downloading", displayName);
        _error = string.Empty;
        _loading = true;
        _windowState.Reset();
        _visible = true;

        await RevokePdfBlobUrlAsync();
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            var bundle = await PreviewFileAccess.TryBuildPreviewBundleAsync(applicationId, entryKey, applicationItemIds)
                .ConfigureAwait(false);

            if (bundle == null || bundle.Originals.Count == 0)
            {
                SetPreviewError(PreviewError);
                return;
            }

            _officeOriginals = bundle.Originals;
            _fileName = bundle.Originals.Count == 1
                ? (string.IsNullOrWhiteSpace(bundle.Original.FileName) ? displayName : bundle.Original.FileName)
                : displayName;

            if (bundle.Originals.Count == 1)
            {
                _officeDownloadContent = bundle.Original.Content;
                _officeDownloadFileName = bundle.Original.FileName;
                _officeContentType = bundle.Original.ContentType;
            }

            _previewLoadingLabel = FormatMsg("ApplicationReportPackage.Preview.Converting", displayName);
            await InvokeAsync(StateHasChanged);
            await Task.Yield();

            var pdfContent = bundle.PdfContent;
            if (pdfContent == null || pdfContent.Length == 0)
            {
                SetPreviewError(PdfConversionError);
                return;
            }

            _pdfDownloadContent = pdfContent;
            _pdfDownloadFileName = bundle.PdfFileName;
            _pdfBlobUrl = await JS.InvokeAsync<string>("visaDocumentCopyPreview.createPdfBlobUrl", pdfContent);
        }
        catch (Exception ex)
        {
            SetPreviewError(PreviewError, ex);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
            await ScheduleViewerLayoutSyncAsync();
        }
    }

    private async Task DownloadPreviewPdfAsync()
    {
        if (_pdfDownloadContent == null || _pdfDownloadContent.Length == 0)
            return;

        using var stream = new MemoryStream(_pdfDownloadContent, writable: false);
        await FileDownloader.DownloadAsync(
            string.IsNullOrWhiteSpace(_pdfDownloadFileName) ? "report-preview.pdf" : _pdfDownloadFileName,
            stream);
    }

    private async Task DownloadOfficeFileAsync()
    {
        if (_officeOriginals.Count > 1)
        {
            using var zipStream = new MemoryStream();
            using (var archive = new ZipArchive(zipStream, ZipArchiveMode.Create, leaveOpen: true))
            {
                var usedNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                foreach (var file in _officeOriginals)
                {
                    var entryName = ZipEntryFileNameSanitizer.EnsureUnique(file.FileName, usedNames);
                    var entry = archive.CreateEntry(entryName, CompressionLevel.Fastest);
                    await using var entryStream = entry.Open();
                    await entryStream.WriteAsync(file.Content);
                }
            }

            zipStream.Position = 0;
            await FileDownloader.DownloadAsync("report-preview.zip", zipStream, "application/zip");
            return;
        }

        if (_officeDownloadContent == null || _officeDownloadContent.Length == 0)
            return;

        using var stream = new MemoryStream(_officeDownloadContent, writable: false);
        await FileDownloader.DownloadAsync(
            string.IsNullOrWhiteSpace(_officeDownloadFileName) ? "report.docx" : _officeDownloadFileName,
            stream,
            _officeContentType);
    }

    private async Task ScheduleViewerLayoutSyncAsync()
    {
        if (!_visible || string.IsNullOrWhiteSpace(_pdfBlobUrl))
            return;

        var generation = ++_layoutSyncGeneration;
        await Task.Delay(150);
        if (generation != _layoutSyncGeneration || !_visible || string.IsNullOrWhiteSpace(_pdfBlobUrl))
            return;

        await JS.InvokeVoidAsync("visaDocumentCopyPreview.syncViewerHeight");
    }

    private Task OnPopupShown() =>
        !string.IsNullOrWhiteSpace(_pdfBlobUrl) && !_loading
            ? ScheduleViewerLayoutSyncAsync()
            : Task.CompletedTask;

    private async Task CloseAsync()
    {
        _visible = false;
        await ResetStateAsync();
    }

    private async Task OnVisibleChanged(bool visible)
    {
        _visible = visible;
        if (!visible)
            await ResetStateAsync();
    }

    private async Task ResetStateAsync()
    {
        _layoutSyncGeneration++;
        _fileName = string.Empty;
        _error = string.Empty;
        _loading = false;
        _previewLoadingLabel = string.Empty;
        _pdfDownloadContent = null;
        _pdfDownloadFileName = string.Empty;
        _officeDownloadContent = null;
        _officeDownloadFileName = string.Empty;
        _officeContentType = "application/octet-stream";
        _officeOriginals = Array.Empty<ApplicationWordReportGeneratedFile>();
        await RevokePdfBlobUrlAsync();
        _windowState.Reset();
    }

    private async Task ToggleMinimizeAsync()
    {
        _windowState.ToggleMinimize(_windowState.Width, _windowState.Height);
        await AfterWindowModeChangedAsync();
    }

    private async Task ToggleMaximizeAsync()
    {
        _windowState.ToggleMaximize(_windowState.Width, _windowState.Height);
        await AfterWindowModeChangedAsync();
    }

    private async Task AfterWindowModeChangedAsync()
    {
        await InvokeAsync(StateHasChanged);
        if (!_windowState.IsMinimized)
            await ScheduleViewerLayoutSyncAsync();
    }

    private async Task RevokePdfBlobUrlAsync()
    {
        if (string.IsNullOrWhiteSpace(_pdfBlobUrl))
            return;

        await JS.InvokeVoidAsync("visaDocumentCopyPreview.revokePdfBlobUrl", _pdfBlobUrl);
        _pdfBlobUrl = null;
    }

    private void OnResizeStarted(PopupResizeStartedEventArgs args)
    {
        _windowState.ApplyManualResize($"{args.Size.Width}px", $"{args.Size.Height}px");
    }

    private Task OnResizeCompleted(PopupResizeCompletedEventArgs args)
    {
        _windowState.ApplyManualResize($"{args.Size.Width}px", $"{args.Size.Height}px");
        return ScheduleViewerLayoutSyncAsync();
    }
}
