@namespace Visa2026.Blazor.Server.Editors
@using DevExpress.Blazor
@using Microsoft.AspNetCore.Components
@using System.IO
@using Microsoft.JSInterop
@using DevExpress.ExpressApp.Blazor.Services
@using Visa2026.Blazor.Server.Services
@using Visa2026.Module.Localization
@using Visa2026.Module.Services
@using Visa2026.Module.Services.ApplicationItemLinkedDocuments
@inject ApplicationItemDocumentFileAccess FileAccess
@inject IFileDownloader FileDownloader
@inject IXafCultureInfoService CultureInfoService
@inject IJSRuntime JS

<DxPopup Visible="_visible"
         VisibleChanged="OnVisibleChanged"
         ShowFooter="false"
         ShowCloseButton="false"
         CloseOnOutsideClick="false"
         AllowResize="@(!_applicationFormMode)"
         Scrollable="false"
         Width="@_popupWidth"
         Height="@_popupHeight"
         MinWidth="480px"
         MinHeight="360px"
         MaxWidth="98vw"
         MaxHeight="95vh"
         ResizeStarted="OnResizeStarted"
         ResizeCompleted="OnResizeCompleted"
         Shown="OnPopupShown"
         CssClass="app-item-doc-copies-preview-popup"
         Attributes="@PopupAttributes">
    <HeaderContentTemplate>
        <div class="app-item-doc-copies-preview__header">
            <h2 class="app-item-doc-copies-preview__title" id="app-item-doc-copies-preview-title">@HeaderText</h2>
            <div class="app-item-doc-copies-preview__header-actions">
                @if (!_loading && !_applicationFormMode && _pdfDownloadContent != null)
                {
                    <DxButton Text="@ActionDownload"
                              RenderStyle="ButtonRenderStyle.Link"
                              SizeMode="SizeMode.Small"
                              Click="@DownloadPreviewPdfAsync" />
                }
                @if (!_loading && ShowBatchSummaryAction)
                {
                    <DxButton Text="@ActionBatchSummary"
                              RenderStyle="ButtonRenderStyle.Link"
                              SizeMode="SizeMode.Small"
                              Click="@DownloadBatchSummaryAsync" />
                }
                <DxButton Text="@ActionClose"
                          RenderStyle="ButtonRenderStyle.Primary"
                          SizeMode="SizeMode.Small"
                          Click="@CloseAsync" />
            </div>
        </div>
    </HeaderContentTemplate>
    <BodyContentTemplate>
        <div class="app-item-doc-copies-preview">
            @if (_loading)
            {
                <div class="app-item-doc-copies-preview__state" role="status">@PreviewLoading</div>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="app-item-doc-copies-preview__state app-item-doc-copies-preview__state--error" role="alert">@_error</div>
            }
            else if (_applicationFormMode)
            {
                <div class="app-item-doc-copies-preview__application-form">
                    <p class="app-item-doc-copies-preview__application-form-message">@ApplicationFormDownloadNotice</p>
                    <DxButton Text="@ActionDownload"
                              RenderStyle="ButtonRenderStyle.Link"
                              SizeMode="SizeMode.Small"
                              CssClass="app-item-doc-copies-preview__application-form-download"
                              Click="@DownloadApplicationFormAsync" />
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_pdfBlobUrl))
            {
                <div class="app-item-doc-copies-preview__viewer-shell">
                    <iframe class="app-item-doc-copies-preview__iframe"
                            src="@_pdfBlobUrl"
                            title="@_fileName"
                            allow="fullscreen"></iframe>
                </div>
            }
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    [Parameter] public IReadOnlyList<Guid> ApplicationItemIds { get; set; } = Array.Empty<Guid>();

    [Parameter] public ApplicationItemDocumentPackageOptions PackageOptions { get; set; } =
        ApplicationItemDocumentPackageOptions.CreateDefaults();

    private bool _visible;
    private string _fileName = string.Empty;
    private string _error = string.Empty;
    private bool _loading;
    private string? _pdfBlobUrl;
    private byte[]? _pdfDownloadContent;
    private string _pdfDownloadFileName = string.Empty;
    private string _activeSlotKey = string.Empty;
    private bool _applicationFormMode;
    private byte[]? _applicationFormContent;
    private string _applicationFormFileName = string.Empty;
    private string _applicationFormContentType = "application/pdf";
    private string _popupWidth = DefaultPopupWidth;
    private string _popupHeight = DefaultPopupHeight;
    private int _layoutSyncGeneration;

    private const string DefaultPopupWidth = "min(98vw, 1200px)";
    private const string DefaultPopupHeight = "min(95vh, 960px)";
    private const string ApplicationFormPopupWidth = "min(92vw, 560px)";
    private const string ApplicationFormPopupHeight = "auto";

    private Dictionary<string, object> PopupAttributes => new()
    {
        ["aria-labelledby"] = "app-item-doc-copies-preview-title"
    };

    private string EffectiveUiCulture =>
        VisaUiMessages.NormalizeCultureName(CultureInfoService.CurrentUICulture.Name);

    private string Msg(string key) => VisaUiMessages.Get(key, EffectiveUiCulture);

    private string FormSlotLabel => Msg("ApplicationItemDocumentCopies.Slot.ApplicationForm");

    private string HeaderText => _applicationFormMode
        ? $"{PreviewTitle}: {FormSlotLabel}"
        : string.IsNullOrWhiteSpace(_fileName)
            ? PreviewTitle
            : $"{PreviewTitle}: {_fileName}";

    private string PreviewTitle => Msg("ApplicationItemDocumentCopies.Preview.Title");
    private string PreviewLoading => Msg("ApplicationItemDocumentCopies.Preview.Loading");
    private string PreviewError => Msg("ApplicationItemDocumentCopies.Preview.Error");
    private string ApplicationFormDownloadNotice => _applicationFormContentType == "application/zip"
        ? Msg("ApplicationItemDocumentCopies.Preview.ApplicationFormZipDownloaded")
        : Msg("ApplicationItemDocumentCopies.Preview.ApplicationFormDownloaded");
    private string ActionClose => Msg("ApplicationItemDocumentCopies.Action.Close");
    private string ActionDownload => Msg("ApplicationItemDocumentCopies.Action.Download");
    private string ActionBatchSummary => Msg("ApplicationItemDocumentCopies.Action.BatchSummary");

    private bool ShowBatchSummaryAction =>
        !string.IsNullOrWhiteSpace(_activeSlotKey)
        && ApplicationItemIds.Count >= 2
        && ApplicationItemDocumentBatchSummaryKindMapping.TryFromSlotKey(_activeSlotKey, PackageOptions, out _);

    public async Task OpenMergedSlotAsync(string slotKey, string slotLabel)
    {
        _activeSlotKey = slotKey;
        await OpenPdfAsync(
            slotLabel,
            () =>
            {
                if (!FileAccess.TryGetMergedSlotPdf(ApplicationItemIds, slotKey, out var result) || result == null)
                    return (null, null, PreviewError);

                return (result.Content, result.FileName, null);
            });
    }

    public async Task OpenFilledApplicationFormAsync(IReadOnlyList<Guid>? applicationItemIds = null)
    {
        var itemIds = applicationItemIds ?? ApplicationItemIds;

        _activeSlotKey = string.Empty;
        _applicationFormMode = true;
        _applicationFormContent = null;
        _applicationFormFileName = string.Empty;
        _fileName = FormSlotLabel;
        _error = string.Empty;
        _loading = true;
        _popupWidth = ApplicationFormPopupWidth;
        _popupHeight = ApplicationFormPopupHeight;
        _visible = true;

        await RevokePdfBlobUrlAsync();

        try
        {
            if (!FileAccess.TryGetFilledApplicationFormPdf(itemIds, out var result, out var errorMessageKey)
                || result == null)
            {
                _error = !string.IsNullOrWhiteSpace(errorMessageKey)
                    ? Msg(errorMessageKey)
                    : PreviewError;
                return;
            }

            _applicationFormContent = result.Content;
            _applicationFormFileName = result.FileName;
            _applicationFormContentType = result.ContentType;
            await DownloadApplicationFormAsync();
        }
        catch (Exception)
        {
            _error = PreviewError;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenPdfAsync(
        string headerLabel,
        Func<(byte[]? Content, string? FileName, string? Error)> loadPdf)
    {
        _applicationFormMode = false;
        _applicationFormContent = null;
        _applicationFormFileName = string.Empty;
        _applicationFormContentType = "application/pdf";
        _pdfDownloadContent = null;
        _pdfDownloadFileName = string.Empty;
        _fileName = headerLabel;
        _error = string.Empty;
        _loading = true;
        _popupWidth = DefaultPopupWidth;
        _popupHeight = DefaultPopupHeight;
        _visible = true;

        await RevokePdfBlobUrlAsync();

        try
        {
            var (content, fileName, error) = loadPdf();
            if (!string.IsNullOrWhiteSpace(error))
            {
                _error = error;
                return;
            }

            if (content == null || content.Length == 0)
            {
                _error = PreviewError;
                return;
            }

            _fileName = string.IsNullOrWhiteSpace(fileName) ? headerLabel : fileName;
            _pdfDownloadContent = content;
            _pdfDownloadFileName = string.IsNullOrWhiteSpace(fileName) ? "document-copies.pdf" : fileName;
            _pdfBlobUrl = await JS.InvokeAsync<string>("visaDocumentCopyPreview.createPdfBlobUrl", content);
        }
        catch (Exception)
        {
            _error = PreviewError;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
            await ScheduleViewerLayoutSyncAsync();
        }
    }

    private async Task DownloadApplicationFormAsync()
    {
        if (_applicationFormContent == null || _applicationFormContent.Length == 0)
            return;

        using var stream = new MemoryStream(_applicationFormContent, writable: false);
        await FileDownloader.DownloadAsync(
            string.IsNullOrWhiteSpace(_applicationFormFileName) ? "ApplicationForm.pdf" : _applicationFormFileName,
            stream,
            _applicationFormContentType);
    }

    private async Task DownloadPreviewPdfAsync()
    {
        if (_pdfDownloadContent == null || _pdfDownloadContent.Length == 0)
            return;

        using var stream = new MemoryStream(_pdfDownloadContent, writable: false);
        await FileDownloader.DownloadAsync(
            string.IsNullOrWhiteSpace(_pdfDownloadFileName) ? "document-copies.pdf" : _pdfDownloadFileName,
            stream);
    }

    private async Task DownloadBatchSummaryAsync()
    {
        if (!ApplicationItemDocumentBatchSummaryKindMapping.TryFromSlotKey(_activeSlotKey, PackageOptions, out var kind)
            || !FileAccess.TryGetBatchSummaryPdf(ApplicationItemIds, kind, PackageOptions, out var result)
            || result == null)
        {
            _error = PreviewError;
            await InvokeAsync(StateHasChanged);
            return;
        }

        using var stream = new MemoryStream(result.Content, writable: false);
        await FileDownloader.DownloadAsync(result.FileName, stream, result.ContentType);
    }

    private async Task ScheduleViewerLayoutSyncAsync()
    {
        if (!_visible || string.IsNullOrWhiteSpace(_pdfBlobUrl) || _applicationFormMode)
            return;

        var generation = ++_layoutSyncGeneration;
        await Task.Delay(150);
        if (generation != _layoutSyncGeneration || !_visible || string.IsNullOrWhiteSpace(_pdfBlobUrl))
            return;

        await JS.InvokeVoidAsync("visaDocumentCopyPreview.syncViewerHeight");
    }

    private Task OnPopupShown() =>
        !string.IsNullOrWhiteSpace(_pdfBlobUrl) && !_loading && !_applicationFormMode
            ? ScheduleViewerLayoutSyncAsync()
            : Task.CompletedTask;

    private async Task CloseAsync()
    {
        _visible = false;
        await ResetStateAsync();
    }

    private async Task OnVisibleChanged(bool visible)
    {
        _visible = visible;
        if (!visible)
            await ResetStateAsync();
    }

    private async Task ResetStateAsync()
    {
        _layoutSyncGeneration++;
        _fileName = string.Empty;
        _error = string.Empty;
        _loading = false;
        _applicationFormMode = false;
        _applicationFormContent = null;
        _applicationFormFileName = string.Empty;
        _applicationFormContentType = "application/pdf";
        _activeSlotKey = string.Empty;
        _pdfDownloadContent = null;
        _pdfDownloadFileName = string.Empty;
        await RevokePdfBlobUrlAsync();
        _popupWidth = DefaultPopupWidth;
        _popupHeight = DefaultPopupHeight;
    }

    private async Task RevokePdfBlobUrlAsync()
    {
        if (string.IsNullOrWhiteSpace(_pdfBlobUrl))
            return;

        await JS.InvokeVoidAsync("visaDocumentCopyPreview.revokePdfBlobUrl", _pdfBlobUrl);
        _pdfBlobUrl = null;
    }

    private void OnResizeStarted(PopupResizeStartedEventArgs args)
    {
        _popupWidth = $"{args.Size.Width}px";
        _popupHeight = $"{args.Size.Height}px";
    }

    private Task OnResizeCompleted(PopupResizeCompletedEventArgs args)
    {
        _popupWidth = $"{args.Size.Width}px";
        _popupHeight = $"{args.Size.Height}px";
        return ScheduleViewerLayoutSyncAsync();
    }
}
