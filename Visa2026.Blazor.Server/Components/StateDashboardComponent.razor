        var owners = WebUtility.HtmlEncode(ownersSql);
        var eval = WebUtility.HtmlEncode(evaluationSql);
        return new MarkupString(
            "<details style=\"display:inline-block; text-align:left;\">" +
            "<summary style=\"list-style:none; cursor:pointer; outline:none;\">" +
            "<span style=\"background:#cfe2ff; color:#084298; font-size:0.63rem; font-weight:700; padding:1px 6px; border-radius:10px;\">SQL</span>" +
            "</summary>" +
            "<div style=\"margin-top:6px; min-width:360px; max-width:560px; background:#fff; border:1px solid #dee2e6; border-radius:6px; padding:8px; box-shadow:0 2px 8px rgba(0,0,0,0.12);\">" +
            "<div style=\"font-size:0.68rem; color:#495057; margin-bottom:6px;\"><strong>Human:</strong> " + human + "</div>" +
            "<div style=\"font-size:0.68rem; color:#495057; margin-bottom:4px;\"><strong>Real SQL (count query):</strong></div>" +
            "<pre style=\"margin:0 0 6px 0; white-space:pre-wrap; word-break:break-word; font-size:0.67rem; line-height:1.25; color:#212529; background:#f8f9fa; border:1px solid #e9ecef; border-radius:4px; padding:6px; user-select:text;\">" + count + "</pre>" +
            "<div style=\"font-size:0.68rem; color:#495057; margin-bottom:4px;\"><strong>Real SQL (owner rows for navigation):</strong></div>" +
            "<pre style=\"margin:0 0 6px 0; white-space:pre-wrap; word-break:break-word; font-size:0.67rem; line-height:1.25; color:#212529; background:#f8f9fa; border:1px solid #e9ecef; border-radius:4px; padding:6px; user-select:text;\">" + owners + "</pre>" +
            "<div style=\"font-size:0.68rem; color:#495057; margin-bottom:4px;\"><strong>Human-readable SQL (state evaluation rule):</strong></div>" +
            "<pre style=\"margin:0; white-space:pre-wrap; word-break:break-word; font-size:0.67rem; line-height:1.25; color:#212529; background:#f8f9fa; border:1px solid #e9ecef; border-radius:4px; padding:6px; user-select:text;\">" + eval + "</pre>" +
            "</div>" +
            "</details>");
    }
