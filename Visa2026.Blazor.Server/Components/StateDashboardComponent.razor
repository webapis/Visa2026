    private async Task LoadExpiredCheckoutStatesFromSnapshotsAsync(Visa2026EFCoreDbContext db)
    {
        _registrationStatePersonIds[VisaV06StateCodes.ExpiredToBeCheckedOut] = new List<Guid>();
        _registrationStatePersonIds[VisaV06StateCodes.ExpiredOnCheckOutProcess] = new List<Guid>();
        _registrationStatePersonIds[VisaV06StateCodes.ExpiredCheckedOut] = new List<Guid>();
        _registrationStatePersonIds[VisaV06StateCodes.ExpiredMissedTimelyCheckout] = new List<Guid>();
        _registrationStateVisaIds[VisaV06StateCodes.ExpiredToBeCheckedOut] = new List<Guid>();
        _registrationStateVisaIds[VisaV06StateCodes.ExpiredOnCheckOutProcess] = new List<Guid>();
        _registrationStateVisaIds[VisaV06StateCodes.ExpiredCheckedOut] = new List<Guid>();
        _registrationStateVisaIds[VisaV06StateCodes.ExpiredMissedTimelyCheckout] = new List<Guid>();
        _counts[VisaV06StateCodes.ExpiredToBeCheckedOut] = 0;
        _counts[VisaV06StateCodes.ExpiredOnCheckOutProcess] = 0;
        _counts[VisaV06StateCodes.ExpiredCheckedOut] = 0;
        _counts[VisaV06StateCodes.ExpiredMissedTimelyCheckout] = 0;

        var activeSnapshots = await db.BoStateSnapshots
            .Where(s => s.OwnerType == "Visa" && s.IsActive && VisaV06StateCodes.All.Contains(s.StateCode))
            .Select(s => new { s.OwnerId, s.StateCode })
            .ToListAsync();

        if (activeSnapshots.Count == 0)
            return;

        var visaIds = activeSnapshots.Select(x => x.OwnerId).Distinct().ToList();
        var visaToPerson = await db.Visas
            .Where(v => visaIds.Contains(v.ID) && v.Passport != null && v.Passport.Person != null)
            .Select(v => new { VisaId = v.ID, PersonId = v.Passport.Person.ID })
            .ToDictionaryAsync(x => x.VisaId, x => x.PersonId);

        foreach (var row in activeSnapshots)
        {
            _counts[row.StateCode] = _counts.GetValueOrDefault(row.StateCode) + 1;
            if (!_registrationStateVisaIds[row.StateCode].Contains(row.OwnerId))
                _registrationStateVisaIds[row.StateCode].Add(row.OwnerId);
            if (visaToPerson.TryGetValue(row.OwnerId, out var personId) &&
                !_registrationStatePersonIds[row.StateCode].Contains(personId))
            {
                _registrationStatePersonIds[row.StateCode].Add(personId);
            }
        }
    }

    private async Task NavigateWithVisaState(string stateKey, string caption)
    {
        var ids = _registrationStatePersonIds.TryGetValue(stateKey, out var candidateIds)
            ? candidateIds
            : new List<Guid>();
        _logger.LogInformation(
            "V06 navigate visa state={StateKey} caption={Caption} count={Count} ids={Ids}",
            stateKey,
            caption,
            ids.Count,
            FormatPersonIds(ids));
        _visaStateFilterService.SetPending(
            ids,
            caption);
        await NavigateWithPendingAsync(
            () => { },
            "/Visa_ListView");
    }

    private async Task NavigateWithPendingAsync(Action setPending, string url)
    {
        if (_disposed)
            return;

        _navigating = true;
        await SafeStateHasChangedAsync();

        setPending();
        _nav.NavigateTo(url);

        try
        {
            await Task.Delay(2500, _disposeCts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (_disposed)
            return;

        _navigating = false;
        await SafeStateHasChangedAsync();
    }

    private async Task SafeStateHasChangedAsync()
    {
        if (_disposed)
            return;

        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    public void Dispose()
    {
        _disposed = true;
        if (!_disposeCts.IsCancellationRequested)
            _disposeCts.Cancel();
        _disposeCts.Dispose();
    }

    private async Task ComputeExpiredCheckoutStatesAsync(Visa2026EFCoreDbContext db, DateTime today)
    {
        _registrationStatePersonIds["Visa|ExpiredToBeCheckedOut"] = new List<Guid>();
        _registrationStatePersonIds["Visa|ExpiredOnCheckOutProcess"] = new List<Guid>();
        _registrationStatePersonIds["Visa|ExpiredCheckedOut"] = new List<Guid>();
        _registrationStatePersonIds["Visa|ExpiredMissedTimelyCheckout"] = new List<Guid>();
        _registrationStateVisaIds["Visa|ExpiredToBeCheckedOut"] = new List<Guid>();
        _registrationStateVisaIds["Visa|ExpiredOnCheckOutProcess"] = new List<Guid>();
        _registrationStateVisaIds["Visa|ExpiredCheckedOut"] = new List<Guid>();
        _registrationStateVisaIds["Visa|ExpiredMissedTimelyCheckout"] = new List<Guid>();
        _counts["Visa|ExpiredToBeCheckedOut"] = 0;
        _counts["Visa|ExpiredOnCheckOutProcess"] = 0;
        _counts["Visa|ExpiredCheckedOut"] = 0;
        _counts["Visa|ExpiredMissedTimelyCheckout"] = 0;

        var expiredVisas = await db.Visas
            .Where(v => v.IsActive && !v.IsCancelled && !v.IsDeleted
                && v.ExpirationDate.HasValue && v.ExpirationDate.Value < today
                && v.Passport != null && v.Passport.Person != null)
            .Select(v => new
            {
                v.ID,
                PersonId = v.Passport.Person.ID,
                ExpirationDate = v.ExpirationDate.Value
            })
            .ToListAsync();

        // Registration is a hard prerequisite for V-06a..d.
        // If a person has no registration linked to the same visa, none of these states match.
        var registeredVisaPairs = await db.Set<Registration>()
            .Where(r => !r.IsDeleted
                && r.Person != null
                && r.CurrentVisa != null)
            .Select(r => new
            {
                PersonId = r.Person.ID,
                VisaId = r.CurrentVisa.ID
            })
            .Distinct()
            .ToListAsync();
        var registeredVisaPairSet = registeredVisaPairs
            .Select(x => $"{x.PersonId:N}|{x.VisaId:N}")
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var checkoutRegs = await db.Set<Registration>()
            .Where(r => !r.IsDeleted && r.Person != null && r.Application != null && !r.Application.IsDeleted
                && r.Application.ApplicationType != null && r.Application.ApplicationType.Name == "App_Reg_Check_Out"
                && r.CurrentVisa != null)
            .Select(r => new
            {
                PersonId = r.Person.ID,
                VisaId = r.CurrentVisa.ID,
                ApplicationId = r.Application.ID,
                ApplicationDate = r.Application.ApplicationDate
            })
            .ToListAsync();

        var checkoutAppIds = checkoutRegs.Select(x => x.ApplicationId).Distinct().ToList();
        var latestProgressByApp = await db.ApplicationProgresses
            .Where(ap => checkoutAppIds.Contains(ap.Application.ID))
            .Select(ap => new
            {
                ApplicationId = ap.Application.ID,
                ap.ID,
                ap.Date,
                StateCode = ap.State != null ? ap.State.Code : null
            })
            .ToListAsync();

        var latestStateCodeByApp = latestProgressByApp
            .GroupBy(x => x.ApplicationId)
            .Select(g => g.OrderByDescending(x => x.Date).ThenByDescending(x => x.ID).First())
            .ToDictionary(x => x.ApplicationId, x => x.StateCode);

        var latestCheckoutByVisa = checkoutRegs
            .GroupBy(x => new { x.PersonId, x.VisaId })
            .Select(g => g.OrderByDescending(x => x.ApplicationDate).ThenByDescending(x => x.ApplicationId).First())
            .ToDictionary(
                x => $"{x.PersonId:N}|{x.VisaId:N}",
                x => latestStateCodeByApp.TryGetValue(x.ApplicationId, out var code) ? code : null);

        foreach (var visa in expiredVisas)
        {
            if (!registeredVisaPairSet.Contains($"{visa.PersonId:N}|{visa.ID:N}"))
                continue;

            string stateKey;
            if (latestCheckoutByVisa.TryGetValue($"{visa.PersonId:N}|{visa.ID:N}", out var stateCode))
            {
                stateKey = stateCode == "PROCESS_ISSUED"
                    ? "Visa|ExpiredCheckedOut"
                    : "Visa|ExpiredOnCheckOutProcess";
            }
            else
            {
                var workingDays = CountWorkingDaysAfter(visa.ExpirationDate.Date, today.Date);
                if (workingDays > 3)
                    stateKey = "Visa|ExpiredMissedTimelyCheckout";
                else if (workingDays <= 3)
                    stateKey = "Visa|ExpiredToBeCheckedOut";
                else
                    continue;
            }

            _counts[stateKey] = _counts.GetValueOrDefault(stateKey) + 1;
            if (!_registrationStateVisaIds[stateKey].Contains(visa.ID))
                _registrationStateVisaIds[stateKey].Add(visa.ID);
            if (!_registrationStatePersonIds[stateKey].Contains(visa.PersonId))
                _registrationStatePersonIds[stateKey].Add(visa.PersonId);
        }
    }

    private static int CountWorkingDaysAfter(DateTime fromDate, DateTime toDate)
    {
        if (toDate <= fromDate) return 0;
        var count = 0;
        for (var d = fromDate.AddDays(1); d <= toDate; d = d.AddDays(1))
        {
            if (d.DayOfWeek is not DayOfWeek.Saturday and not DayOfWeek.Sunday)
                count++;
        }
        return count;
    }

    private void LogV06StateSummary(string source)
    {
        var keys = new[]
        {
            VisaV06StateCodes.ExpiredToBeCheckedOut,
            VisaV06StateCodes.ExpiredOnCheckOutProcess,
            VisaV06StateCodes.ExpiredCheckedOut,
            VisaV06StateCodes.ExpiredMissedTimelyCheckout
        };

        foreach (var key in keys)
        {
            var count = _counts.TryGetValue(key, out var c) ? c : 0;
            var ids = _registrationStatePersonIds.TryGetValue(key, out var personIds)
                ? personIds
                : new List<Guid>();
            _logger.LogInformation(
                "V06 summary source={Source} state={StateKey} count={Count} personCount={PersonCount} ids={Ids}",
                source,
                key,
                count,
                ids.Count,
                FormatPersonIds(ids));
        }
    }

    private static string FormatPersonIds(IReadOnlyCollection<Guid> ids)
    {
        if (ids == null || ids.Count == 0)
            return "[]";

        var preview = ids.Take(10).Select(x => x.ToString("N")).ToList();
        var suffix = ids.Count > 10 ? $", ... (+{ids.Count - 10})" : string.Empty;
        return $"[{string.Join(", ", preview)}{suffix}]";
    }

