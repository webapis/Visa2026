@using System.Linq
@using DevExpress.Data.Filtering
@using DevExpress.ExpressApp
@using Visa2026.Module.BusinessObjects
@using Visa2026.Module.Services.StateEvaluation
@using Visa2026.Module.Services.StateEvaluation.Evaluators
@inject IObjectSpaceFactory ObjectSpaceFactory
@inject Services.XafApplicationHolder AppHolder

<div style="padding:24px; background:#f5f6fa; min-height:100%; box-sizing:border-box; font-family:inherit;">

    <div style="display:flex; align-items:center; gap:16px; margin-bottom:24px;">
        <span style="font-size:1.1rem; font-weight:600; color:#343a40;">State Dashboard</span>
        <span style="font-size:0.78rem; color:#aaa; margin-left:auto;">@(_loadedAt?.ToString("dd MMM yyyy HH:mm"))</span>
        <button @onclick="Refresh"
                style="padding:4px 14px; border-radius:5px; border:1px solid #ccc; background:white; cursor:pointer; font-size:0.82rem;">
            &#8635; Refresh
        </button>
    </div>

    @if (_sections == null)
    {
        <p style="color:#aaa;">Loading&hellip;</p>
    }
    else
    {
        @foreach (var boSection in _sections)
        {
            <div style="margin-bottom:20px;">
                <div style="margin-bottom:6px; font-size:0.68rem; font-weight:700; letter-spacing:0.09em; color:#aaa; text-transform:uppercase;">
                    @boSection.BoType
                </div>
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    @foreach (var tile in boSection.Tiles)
                    {
                        <div @onclick="() => OpenFilteredList(boSection.BoType, tile.StateCode)"
                             title="Open @boSection.BoType — @tile.Label"
                             style="@TileStyle(tile.Severity) border-radius:7px; padding:10px 18px; min-width:90px;
                                    text-align:center; box-shadow:0 1px 4px rgba(0,0,0,0.08);
                                    cursor:pointer; user-select:none;">
                            <div style="font-size:1.5rem; font-weight:700; line-height:1.2;">@tile.Count</div>
                            <div style="font-size:0.73rem; margin-top:3px; font-weight:500;">@tile.Label</div>
                        </div>
                    }
                </div>
            </div>
        }

        <div style="margin-top:24px; color:#ccc; font-size:0.75rem;">
            @_totalCount records evaluated &mdash; click any tile to open the filtered list
        </div>

    }
</div>

@code {
    private List<BoSection> _sections;
    private DateTime? _loadedAt;
    private int _totalCount;
    private string _navError;

    protected override void OnInitialized() => LoadData();

    private void Refresh() => LoadData();

    private void LoadData()
    {
        try
        {
        using var space = ObjectSpaceFactory.CreateObjectSpace(typeof(Visa));
        var settings = StateEvaluationSettings.FromSystemSettings(SystemSettings.GetInstance(space));

        _sections = new List<BoSection>
        {
            BuildSection("Visas",
                space.GetObjectsQuery<Visa>().ToList()
                     .Select(v => VisaStateEvaluator.Evaluate(v, settings)).ToList()),
            BuildSection("Passports",
                space.GetObjectsQuery<Passport>().ToList()
                     .Select(p => PassportStateEvaluator.Evaluate(p, settings)).ToList()),
            BuildSection("Work Permits",
                space.GetObjectsQuery<WorkPermitItem>().ToList()
                     .Select(w => WorkPermitItemStateEvaluator.Evaluate(w, settings)).ToList()),
            BuildSection("Employee Contracts",
                space.GetObjectsQuery<EmployeeContract>().ToList()
                     .Select(c => EmployeeContractStateEvaluator.Evaluate(c, settings)).ToList()),
            BuildSection("Medical Records",
                space.GetObjectsQuery<MedicalRecord>().ToList()
                     .Select(m => MedicalRecordStateEvaluator.Evaluate(m, settings)).ToList()),
            BuildSection("Addresses of Residence",
                space.GetObjectsQuery<AddressOfResidence>().ToList()
                     .Select(a => AddressOfResidenceStateEvaluator.Evaluate(a, settings)).ToList()),
        };

        _totalCount = _sections.Sum(s => s.Tiles.Sum(t => t.Count));
        _loadedAt = DateTime.Now;
        }
        catch { _sections = null; }
    }

    private XafApplication GetApp() => AppHolder.Application;

    private async Task OpenFilteredList(string boType, string stateCode)
    {
        _navError = null;
        try
        {
            var app = GetApp();
            if (app is null)
            {
                _navError = $"GetApp() returned null — tried XafApplication, BlazorApplication, Visa2026BlazorApplication";
                return;
            }

            using var settingsSpace = app.CreateObjectSpace(typeof(SystemSettings));
            var settings = StateEvaluationSettings.FromSystemSettings(
                SystemSettings.GetInstance(settingsSpace));

            var today = DateTime.Today;
            var soonDate = today.AddDays(settings.DefaultExpiringSoonDays);

            var (objectType, viewId, criteria) = boType switch
            {
                "Visas"                  => (typeof(Visa),                "Visa_ListView",                VisaCriteria(stateCode, today, soonDate)),
                "Passports"              => (typeof(Passport),            "Passport_ListView",            PassportCriteria(stateCode, today, soonDate)),
                "Work Permits"           => (typeof(WorkPermitItem),      "WorkPermitItem_ListView",      WorkPermitCriteria(stateCode, today, soonDate)),
                "Employee Contracts"     => (typeof(EmployeeContract),    "EmployeeContract_ListView",    ContractCriteria(stateCode, today, soonDate)),
                "Medical Records"        => (typeof(MedicalRecord),       "MedicalRecord_ListView",       MedicalCriteria(stateCode, today, soonDate)),
                "Addresses of Residence" => (typeof(AddressOfResidence),  "AddressOfResidence_ListView",  AddressCriteria(stateCode, today, soonDate)),
                _                        => ((Type)null, (string)null, (CriteriaOperator)null)
            };

            if (objectType is null)  { _navError = $"Unknown boType: {boType}"; return; }
            if (criteria is null)    { _navError = $"No criteria for state: {stateCode}"; return; }

            var os = app.CreateObjectSpace(objectType);
            var cs = app.CreateCollectionSource(os, objectType, viewId);
            cs.Criteria["StateFilter"] = criteria;
            var listView = app.CreateListView(viewId, cs, true);

            await InvokeAsync(() => app.ShowViewStrategy.ShowView(
                new ShowViewParameters(listView) { TargetWindow = TargetWindow.Default },
                new ShowViewSource(null, null)));
        }
        catch (Exception ex)
        {
            _navError = ex.GetType().Name + ": " + ex.Message;
        }
    }

    private static BoSection BuildSection(string boType, List<BoStateResult> results)
    {
        var tiles = results
            .GroupBy(r => r.StateCode)
            .Select(g => new StateTile(g.Key, FriendlyLabel(g.Key), g.Count(), g.First().Severity))
            .OrderByDescending(t => (int)t.Severity)
            .ThenBy(t => t.Label)
            .ToList();
        return new BoSection(boType, tiles);
    }

    private static CriteriaOperator VisaCriteria(string code, DateTime today, DateTime soonDate) => code switch
    {
        "Cancelled"    => new BinaryOperator("IsCancelled", true),
        "Expired"      => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.Less)),
        "ExpiringSoon" => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("IsExtended", false),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.GreaterOrEqual),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.LessOrEqual)),
        "Extended"     => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("IsExtended", true)),
        "Changed"      => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("IsChanged", true),
                            new BinaryOperator("IsExtended", false)),
        "Active"       => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("IsExtended", false),
                            new BinaryOperator("IsChanged", false),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.Greater)),
        "Archived"     => CriteriaOperator.And(
                            new BinaryOperator("IsActive", false),
                            new BinaryOperator("IsCancelled", false)),
        _              => null
    };

    private static CriteriaOperator PassportCriteria(string code, DateTime today, DateTime soonDate) => code switch
    {
        "Expired"      => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.Less)),
        "ExpiringSoon" => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.GreaterOrEqual),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.LessOrEqual)),
        "Active"       => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.Greater)),
        "Archived"     => new BinaryOperator("IsActive", false),
        _              => null
    };

    private static CriteriaOperator WorkPermitCriteria(string code, DateTime today, DateTime soonDate) => code switch
    {
        "Cancelled"    => new BinaryOperator("IsCancelled", true),
        "Expired"      => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.Less)),
        "ExpiringSoon" => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("IsExtended", false),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.GreaterOrEqual),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.LessOrEqual)),
        "Extended"     => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("IsExtended", true)),
        "Active"       => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("IsCancelled", false),
                            new BinaryOperator("IsExtended", false),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.Greater)),
        "Archived"     => CriteriaOperator.And(
                            new BinaryOperator("IsActive", false),
                            new BinaryOperator("IsCancelled", false)),
        _              => null
    };

    private static CriteriaOperator ContractCriteria(string code, DateTime today, DateTime soonDate) => code switch
    {
        "Expired"      => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.Less)),
        "ExpiringSoon" => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.GreaterOrEqual),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.LessOrEqual)),
        "Active"       => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.Greater)),
        "Archived"     => new BinaryOperator("IsActive", false),
        _              => null
    };

    private static CriteriaOperator MedicalCriteria(string code, DateTime today, DateTime soonDate) => code switch
    {
        "Expired"      => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.Less)),
        "ExpiringSoon" => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.GreaterOrEqual),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.LessOrEqual)),
        "Active"       => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.Greater)),
        "Archived"     => new BinaryOperator("IsActive", false),
        _              => null
    };

    private static CriteriaOperator AddressCriteria(string code, DateTime today, DateTime soonDate) => code switch
    {
        "Expired"      => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.Less)),
        "ExpiringSoon" => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", today, BinaryOperatorType.GreaterOrEqual),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.LessOrEqual)),
        "Active"       => CriteriaOperator.And(
                            new BinaryOperator("IsActive", true),
                            new BinaryOperator("ExpirationDate", soonDate, BinaryOperatorType.Greater)),
        "Archived"     => new BinaryOperator("IsActive", false),
        _              => null
    };

    private static string FriendlyLabel(string code) => code switch
    {
        "Cancelled"    => "Cancelled",
        "Expired"      => "Expired",
        "ExpiringSoon" => "Expiring Soon",
        "Extended"     => "Extended",
        "Changed"      => "Changed",
        "Active"       => "Active",
        "Archived"     => "Archived",
        _              => code
    };

    private static string TileStyle(StateSeverity s) => s switch
    {
        StateSeverity.Breach or StateSeverity.Critical => "background:#f8d7da; color:#842029;",
        StateSeverity.Warning                          => "background:#fff3cd; color:#664d03;",
        StateSeverity.Info                             => "background:#cfe2ff; color:#084298;",
        _                                              => "background:#ffffff; color:#343a40;"
    };

    private record StateTile(string StateCode, string Label, int Count, StateSeverity Severity);
    private record BoSection(string BoType, List<StateTile> Tiles);
}
