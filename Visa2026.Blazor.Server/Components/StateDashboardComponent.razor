@code {
    private Dictionary<string, int> _counts = new();
    private bool _loaded;
    private bool _loading;
    private bool _navigating;
    private bool _disposed;
    private readonly CancellationTokenSource _disposeCts = new();
    private int _expiringSoonDays = 30;
    private readonly Dictionary<string, List<Guid>> _registrationStatePersonIds = new();
    private readonly Dictionary<string, List<Guid>> _registrationStateVisaIds = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        await SafeStateHasChangedAsync();
        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            _counts.Clear();
            var sysSettings = await db.SystemSettings.FirstOrDefaultAsync();
            _expiringSoonDays = sysSettings?.DefaultExpiringSoonDays ?? 30;
            var today = DateTime.Today;
            var threshold = today.AddDays(_expiringSoonDays);

            // V-01: Active — all active, not-expired visas (matches the view filter on click)
            _counts["Visa|Active"] = await db.Visas
                .Where(v => v.IsActive && !v.IsCancelled && !v.IsExtended && !v.IsDeleted
                    && v.ExpirationDate.HasValue && v.ExpirationDate.Value >= today)
                .CountAsync();

            // Rejection codes shared by V-02a (exclude) and V-02d (include)
            var rejectionCodes = new[] { "1_REVIEW_REJECTED", "2_REVIEW_REJECTED", "PROCESS_REJECTED" };

            // V-02a: expiring soon + extension application active (not cancelled, not rejected, visa not yet extended).
            // Null CurrentStateID (no progress yet) = not cancelled/rejected → include.
            var extVisaIdsOnExt = db.VisaExtensionStatus
                .Where(s => s.CurrentStateID == null ||
                    !db.ApplicationStates.Any(ast => ast.ID == s.CurrentStateID &&
                        (ast.Code == "PROCESS_CANCELLED" || ast.Code == "1_REVIEW_REJECTED" ||
                         ast.Code == "2_REVIEW_REJECTED" || ast.Code == "PROCESS_REJECTED")))
                .Select(s => s.ExpiringVisaID);
            _counts["Visa|ExpiringSoonOnExt"] = await db.Visas
                .Where(v => v.IsActive && !v.IsCancelled && !v.IsExtended && v.ExtensionRequired
                    && v.ExpirationDate.HasValue && v.ExpirationDate.Value >= today && v.ExpirationDate.Value <= threshold
                    && extVisaIdsOnExt.Contains(v.ID))
                .CountAsync();

            // V-02d: expiring soon + extension application rejected
            var extVisaIdsRejected = db.VisaExtensionStatus
                .Where(s => s.CurrentStateID != null &&
                    db.ApplicationStates.Any(ast => ast.ID == s.CurrentStateID &&
                        (ast.Code == "1_REVIEW_REJECTED" || ast.Code == "2_REVIEW_REJECTED" || ast.Code == "PROCESS_REJECTED")))
                .Select(s => s.ExpiringVisaID);
            _counts["Visa|ExpiringSoonExtRejected"] = await db.Visas
                .Where(v => v.IsActive && !v.IsCancelled && !v.IsExtended && v.ExtensionRequired
                    && v.ExpirationDate.HasValue && v.ExpirationDate.Value >= today && v.ExpirationDate.Value <= threshold
                    && extVisaIdsRejected.Contains(v.ID))
                .CountAsync();

            // V-02b: expiring soon + extension not required (user opted out)
            _counts["Visa|ExpiringSoonNotRequired"] = await db.Visas
                .Where(v => v.IsActive && !v.IsCancelled && !v.ExtensionRequired
                    && v.ExpirationDate.HasValue && v.ExpirationDate.Value >= today && v.ExpirationDate.Value <= threshold
                )
                .CountAsync();

            // V-02c: expiring soon + cancellation application exists
            _counts["Visa|ExpiringSoonExtCancelled"] = await db.Visas
                .Where(v => v.IsActive && !v.IsCancelled && !v.IsExtended && v.ExtensionRequired
                    && v.ExpirationDate.HasValue && v.ExpirationDate.Value >= today && v.ExpirationDate.Value <= threshold
                    && v.AssociatedApplicationItems.Any(ai =>
                        !ai.Application.IsDeleted &&
                        (ai.Application.ApplicationType.Name == "App_Cancel_Visa_Ext" ||
                         ai.Application.ApplicationType.Name == "App_Cancel_Visa_and_WP_Ext")
                    )
                )
                .CountAsync();
            var groups = await db.VisaExtensionStatus
                .Where(s => s.CurrentStateID != null)
                .Join(db.ApplicationStates,
                    s => s.CurrentStateID,
                    ast => ast.ID,
                    (s, ast) => ast.Code)
                .GroupBy(c => c)
                .Select(g => new { Code = g.Key, Count = g.Count() })
                .ToListAsync();
            foreach (var g in groups)
                _counts[$"VisaExt|{g.Code}"] = g.Count;
            // V-15: PROCESS_ISSUED only counts when a new visa was actually issued (IssuedVisaID set)
            _counts["VisaExt|PROCESS_ISSUED"] = await db.VisaExtensionStatus
                .Where(s => s.IssuedVisaID != null)
                .Join(db.ApplicationStates,
                    s => s.CurrentStateID,
                    ast => ast.ID,
                    (s, ast) => ast.Code)
                .Where(code => code == "PROCESS_ISSUED")
                .CountAsync();

            // V-16/17/18: Transfer states (App_Change_Passport)
            var transferGroups = await db.VisaTransferStatus
                .Where(s => s.CurrentStateID != null)
                .Join(db.ApplicationStates,
                    s => s.CurrentStateID,
                    ast => ast.ID,
                    (s, ast) => ast.Code)
                .GroupBy(c => c)
                .Select(g => new { Code = g.Key, Count = g.Count() })
                .ToListAsync();
            foreach (var g in transferGroups)
                _counts[$"VisaTransfer|{g.Code}"] = g.Count;
            // V-17: PROCESS_ISSUED only counts when the new visa was actually issued (IssuedVisaID set)
            _counts["VisaTransfer|PROCESS_ISSUED"] = await db.VisaTransferStatus
                .Where(s => s.IssuedVisaID != null)
                .Join(db.ApplicationStates,
                    s => s.CurrentStateID,
                    ast => ast.ID,
                    (s, ast) => ast.Code)
                .Where(code => code == "PROCESS_ISSUED")
                .CountAsync();

            // Keep dashboard resilient: if snapshot pipeline is not ready (e.g. table not created yet),
            // fall back to inline V-06 computation so the rest of dashboard still loads.
            try
            {
                await _visaV06SnapshotService.RecomputeAsync(today);
                await LoadExpiredCheckoutStatesFromSnapshotsAsync(db);
                LogV06StateSummary("snapshot");
            }
            catch (Exception ex)
            {
                _logger.LogWarning(ex, "V06 snapshot recompute/read failed; using fallback inline calculation.");
                await ComputeExpiredCheckoutStatesAsync(db, today);
                LogV06StateSummary("fallback");
            }
            _loaded = true;

            // V-5a/b/c/d: Cancellation sub-states — in separate try so a missing view doesn't blank all other counts
            try
            {
                _counts["Visa|CancelOnCancellation"] = await db.VisaCancellationStatus
                    .Where(s => s.CurrentStateID == null ||
                        !db.ApplicationStates.Any(ast => ast.ID == s.CurrentStateID && ast.Code == "PROCESS_ISSUED"))
                    .CountAsync();

                _counts["Visa|CancelToBeCheckedOut"] = await db.VisaCancellationStatus
                    .Where(s => s.CurrentStateID != null &&
                        db.ApplicationStates.Any(ast => ast.ID == s.CurrentStateID && ast.Code == "PROCESS_ISSUED") &&
                        s.CheckOutStateID == null)
                    .CountAsync();

                _counts["Visa|CancelOnCheckOut"] = await db.VisaCancellationStatus
                    .Where(s => s.CurrentStateID != null &&
                        db.ApplicationStates.Any(ast => ast.ID == s.CurrentStateID && ast.Code == "PROCESS_ISSUED") &&
                        s.CheckOutStateID != null &&
                        !db.ApplicationStates.Any(ast => ast.ID == s.CheckOutStateID && ast.Code == "PROCESS_ISSUED"))
                    .CountAsync();

                _counts["Visa|CancelIsCheckedOut"] = await db.VisaCancellationStatus
                    .Where(s => s.CurrentStateID != null &&
                        db.ApplicationStates.Any(ast => ast.ID == s.CurrentStateID && ast.Code == "PROCESS_ISSUED") &&
                        s.CheckOutStateID != null &&
                        db.ApplicationStates.Any(ast => ast.ID == s.CheckOutStateID && ast.Code == "PROCESS_ISSUED"))
                    .CountAsync();
            }
            catch { }
        }
        catch { }
        _loading = false;
        await SafeStateHasChangedAsync();
    }

    private MarkupString CountBadgeInfo(string key)
    {
        if (!_loaded) return new MarkupString("<span style=\"color:#adb5bd; font-weight:600;\">—</span>");
        if (!_counts.TryGetValue(key, out var count))
            return new MarkupString("<span style=\"color:#adb5bd; font-weight:600;\">—</span>");
        if (count > 0)
            return new MarkupString($"<span style=\"background:#cfe2ff; color:#084298; font-size:0.75rem; font-weight:700; padding:1px 9px; border-radius:10px; display:inline-block; min-width:26px; text-align:center;\">{count}</span>");
        return new MarkupString("<span style=\"color:#ced4da; font-weight:600;\">0</span>");
    }

    private MarkupString CountBadgeWithSeverity(string key, string severity)
    {
        if (!_loaded) return new MarkupString("<span style=\"color:#adb5bd; font-weight:600;\">—</span>");
        if (!_counts.TryGetValue(key, out var count))
            return new MarkupString("<span style=\"color:#adb5bd; font-weight:600;\">—</span>");
        if (count > 0)
        {
            var (bg, fg) = severity switch
            {
                "Critical" => ("#f8d7da", "#842029"),
                "Warning"  => ("#fff3cd", "#664d03"),
                "Healthy"  => ("#d1e7dd", "#0f5132"),
                "Archived" => ("#e9ecef", "#6c757d"),
                _          => ("#cfe2ff", "#084298"),
            };
            return new MarkupString($"<span style=\"background:{bg}; color:{fg}; font-size:0.75rem; font-weight:700; padding:1px 9px; border-radius:10px; display:inline-block; min-width:26px; text-align:center;\">{count}</span>");
        }
        return new MarkupString("<span style=\"color:#ced4da; font-weight:600;\">0</span>");
    }

