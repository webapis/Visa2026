                        <tr style="border-bottom:1px solid #f1f3f5;"><td style="padding:4px 8px; text-align:right; color:#adb5bd; font-size:0.68rem;">6a</td><td style="padding:4px 8px;"><a href="javascript:void(0)" style="color:#0d6efd; text-decoration:none; cursor:pointer;" @onclick="@(() => NavigateWithVisaState("Visa|ExpiredToBeCheckedOut", "Expired (To Be Checked Out)"))">Expired (To Be Checked Out)</a></td><td style="padding:4px 8px; text-align:center;"><span style="background:#cfe2ff; color:#084298; font-size:0.63rem; font-weight:700; padding:1px 6px; border-radius:10px;">SQL</span></td><td style="padding:4px 8px; text-align:right;">@CountBadgeWithSeverity("Visa|ExpiredToBeCheckedOut", "Warning")</td></tr>
