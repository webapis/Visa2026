      <Action Id="OpenSourceObject" Caption="Открыть исходный объект" />
      <Action Id="OpenTargetObject" Caption="Открыть целевой объект" />
      <Action Id="Refresh" Caption="Обновить" />
      <Action Id="RefreshPdfMappingsCache" Caption="Обновить сопоставления" />
      <Action Id="RefreshReportVisibilityCache" Caption="Обновить видимость отчётов" />
      <Action Id="ResetSyncRules" Caption="Сбросить правила" />
      <Action Id="ResetViewSettings" Caption="Сбросить вид" />
      <Action Id="RestoreObject" Caption="Восстановить" />
      <Action Id="Save" Caption="Сохранить" />
      <Action Id="SaveAndClose" Caption="Сохранить и закрыть" />
      <Action Id="SaveAndNew" Caption="Сохранить и создать" />
      <Action Id="ShowInDocument" Caption="Показать в документе" />
      <Action Id="ShowInReport" Caption="Показать в отчёте" />
      <Action Id="ShowMyPdfBatches" Caption="Мои PDF-задачи" />
      <Action Id="ShowReportDesigner" Caption="Конструктор отчётов" />
      <Action Id="SoftDelete" Caption="Удалить" />
      <Action Id="ToggleShowDeleted" Caption="Показать удалённые" />
      <Action Id="Unlink" Caption="Отвязать" />
      <Action Id="UserFeedbackMarkFixed" Caption="Отметить исправленным" />
      <Action Id="UserFeedbackMarkInProgress" Caption="Отметить «в работе»" />
      <Action Id="ValidatePlaceholders" Caption="Проверить заполнители" />
      <Action Id="ValidateSyncRules" Caption="Проверить правила" />
      <Action Id="ViewApplicationItemDocumentCopies" Caption="Копии документов" />
      <Action Id="ViewApplicationItemWordReports" Caption="Документы" />
