<?xml version="1.0" encoding="utf-8"?>
<Application Title="Управление визами">
  <ActionDesign>
    <Actions>
      <Action Id="Cancel" Caption="Отмена" />
      <Action Id="ChangePasswordByUser" Caption="Сменить пароль" />
      <Action Id="ClearVisibilityCache" Caption="Очистить кэш видимости" />
      <Action Id="CloneObject" Caption="Клонировать" />
      <Action Id="CloneSyncRule" Caption="Клонировать правило" />
      <Action Id="Delete" Caption="Удалить" />
      <Action Id="DeleteConfirmation" Caption="Подтверждение удаления" />
      <Action Id="DialogCancel" Caption="Отмена" />
      <Action Id="DialogOK" Caption="ОК" />
      <Action Id="DownloadAllApplicationItemsAsPdf" Caption="Скачать всё как PDF" />
      <Action Id="Edit" Caption="Изменить" />
      <Action Id="Export" Caption="Экспорт" />
      <Action Id="ExportToPdf" Caption="Экспорт в PDF" />
      <Action Id="ExportToXlsx" Caption="Экспорт в Excel" />
      <Action Id="ExtractPlaceholders" Caption="Извлечь заполнители" />
