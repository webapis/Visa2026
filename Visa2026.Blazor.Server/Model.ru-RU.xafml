      <Action Id="MyDetails" Caption="Моя учётная запись" />
      <Action Id="New" Caption="Создать" />
      <Action Id="OpenApplicationFromTransferStatus" Caption="Открыть заявку" />
      <Action Id="OpenApplicationFromVisaStatus" Caption="Открыть заявку" />
