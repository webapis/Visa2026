@page "/"
@namespace Visa2026.Blazor.Server
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using DevExpress.ExpressApp.Blazor.Components
@using Visa2026.Module
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var forceXafDbUpdate = HostingEnvironmentFlags.IsForceXafDbUpdate(Configuration);
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <!-- meta name="theme-color" content="#000000" -->
    <link rel="icon" href="images/favicon.svg?v=1" type="image/svg+xml" />
    <title>Visa Management</title>
    <base href="~/" />
    <component type="typeof(BootstrapThemeLink)" render-mode="Static" />
</head>
<body>
    <component type="typeof(SplashScreen)" render-mode="Static" param-Caption='"Visa Management"' param-ImagePath='"images/SplashScreen.svg"' />

    <link href="_content/DevExpress.ExpressApp.Blazor/styles.css" asp-append-version="true" rel="stylesheet" />
    <link href="css/site.css" rel="stylesheet" />
    <!-- Uncomment this link to enable CSS isolation. For more information, refer to the following topic: https://learn.microsoft.com/en-us/aspnet/core/blazor/components/css-isolation -->
    <!-- <link href="Visa2026.Blazor.Server.styles.css" rel="stylesheet"> -->

    <script>
        // IMPORTANT: This script must run BEFORE blazor.server.js / DevExpress scripts.
        // Strategy:
        //   1. Pre-register dx-license (and siblings) as empty custom elements so DevExpress's
        //      connectedCallback never runs — the data-permanent re-insertion watcher is never set up.
        //   2. Intercept customElements.define so DevExpress cannot override our registration.
        //   3. MutationObserver removes any instance that gets inserted.
        //      Without data-permanent active, DevExpress won't fight back → no infinite loop.
        (function () {
            var LICENSE_TAGS = ['dx-license', 'dxrd-license', 'dxd-license', 'dxrv-license'];

            // Step 1: pre-register as empty elements (no connectedCallback)
            LICENSE_TAGS.forEach(function (tag) {
                if (!customElements.get(tag)) {
                    customElements.define(tag, class extends HTMLElement {});
                }
            });

            // Step 2: prevent DevExpress from redefining these tags
            var _define = customElements.define.bind(customElements);
            customElements.define = function (name, ctor, opts) {
                if (LICENSE_TAGS.indexOf(name.toLowerCase()) !== -1) return;
                return _define(name, ctor, opts);
            };

            // Step 3: remove any instance that appears in the DOM
            function removeAll() {
                LICENSE_TAGS.forEach(function (tag) {
                    document.querySelectorAll(tag).forEach(function (el) { el.remove(); });
                });
            }

            // Step 4: remove the "For evaluation purposes only" text warning
            // rendered inside report viewer pages as a DOM element.
            // Strategy: find the innermost element whose trimmed text starts with
            // the warning phrase — that is the tightest wrapper — and remove it.
            var WARNING_TEXT = 'For evaluation purposes only';
            // Web Document Viewer constantly inserts large DOM subtrees. Running removeLicenseText()
            // (querySelectorAll('*')) on every added node pegs the main thread → visible UI trembling.
            function isInsideHighChurnReportingTree(el) {
                for (; el && el.nodeType === 1; el = el.parentElement) {
                    var tag = (el.tagName || '').toLowerCase();
                    if (tag.indexOf('dxrd-') === 0 || tag.indexOf('dxrv-') === 0) return true;
                    var cls = typeof el.className === 'string'
                        ? el.className
                        : (el.className && el.className.baseVal) || '';
                    var c = cls.toLowerCase();
                    if (c.indexOf('dxrd') !== -1 || c.indexOf('dxrv') !== -1 ||
                        c.indexOf('dx-blazor-report') !== -1 || c.indexOf('dxxrd') !== -1)
                        return true;
                }
                return false;
            }
            function removeLicenseText(root) {
                if (!root || root.nodeType !== 1) return;
                var t0 = root.textContent || '';
                if (t0.indexOf(WARNING_TEXT) === -1) return;
                var all = root.querySelectorAll('*');
                for (var i = all.length - 1; i >= 0; i--) {
                    var el = all[i];
                    if (el.childElementCount === 0 &&
                        el.textContent.indexOf(WARNING_TEXT) !== -1) {
                        el.parentElement && el.parentElement.remove();
                        return;
                    }
                }
            }

            // Coalesce DOM mutations to one pass per animation frame. The report viewer adds many
            // nodes per refresh; synchronous work on every mutation competes with layout and reads as trembling.
            var rafId = 0;
            var pendingMutations = [];
            var observer = new MutationObserver(function (mutations) {
                for (var i = 0; i < mutations.length; i++) pendingMutations.push(mutations[i]);
                if (rafId) return;
                rafId = requestAnimationFrame(function flushLicenseObserver() {
                    rafId = 0;
                    var batch = pendingMutations;
                    pendingMutations = [];
                    var foundTag = false;
                    for (var bi = 0; bi < batch.length; bi++) {
                        var m = batch[bi];
                        for (var j = 0; j < m.addedNodes.length; j++) {
                            var n = m.addedNodes[j];
                            if (n.nodeType !== 1) continue;
                            var tag = n.tagName.toLowerCase();
                            if (LICENSE_TAGS.indexOf(tag) !== -1) {
                                foundTag = true;
                                continue;
                            }
                            if (isInsideHighChurnReportingTree(n)) {
                                if ((n.textContent || '').indexOf(WARNING_TEXT) === -1) continue;
                            }
                            removeLicenseText(n);
                        }
                    }
                    if (foundTag) removeAll();
                });
            });

            observer.observe(document.documentElement, { childList: true, subtree: true });
        })();
    </script>

    @if (forceXafDbUpdate)
    {
        <div id="force-xaf-db-update-banner" class="force-xaf-db-update-banner" role="status">
            <strong>FORCE_XAF_DB_UPDATE</strong> is on — XAF runs full DB update on every startup (slow). Turn off in the host environment after ModuleUpdaters have run.
        </div>
    }

    <div id="app-version-badge" class="app-version-badge@(forceXafDbUpdate ? " app-version-badge--with-force-banner" : "")" data-version="@Visa2026Module.VersionDisplay" hidden>
        <small>Version: @Visa2026Module.VersionDisplay</small>
    </div>

    <script>
        // Show build version only on the login route. Blazor navigates via history.pushState/replaceState,
        // so popstate alone misses post-login URL changes and the badge would stay visible over alerts.
        (function () {
            function updateVisibility() {
                var el = document.getElementById('app-version-badge');
                if (!el) return;
                var path = window.location && window.location.pathname ? window.location.pathname : '';
                var show = path.toLowerCase().indexOf('/loginpage') === 0;
                el.hidden = !show;
            }
            function hookHistory(methodName) {
                var original = history[methodName];
                if (typeof original !== 'function') return;
                history[methodName] = function () {
                    var result = original.apply(this, arguments);
                    updateVisibility();
                    return result;
                };
            }
            updateVisibility();
            window.addEventListener('popstate', updateVisibility);
            hookHistory('pushState');
            hookHistory('replaceState');
        })();
    </script>

    <app class="d-none">
        <component type="typeof(App)" render-mode="Server" />
    </app>

    <component type="typeof(AlertsHandler)" render-mode="Server" />

    <div id="blazor-error-ui">
        <component type="typeof(BlazorError)" render-mode="Static" />
    </div>

    <script src="_framework/blazor.server.js"></script>
</body>
</html>
